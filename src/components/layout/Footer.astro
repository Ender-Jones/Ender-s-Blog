---
// 联系方式单源: site.yml socials(经 getSocialLinks)— 换账号只改 yml, 这里不再硬编码.
import { getSocialLinks } from '../../lib/data';

const year = new Date().getFullYear();
const socials = getSocialLinks();
// 每个渠道的胶囊着装(蓝填充/ghost/默认), 与接线前的手写版一致.
const pillStyle = {
  github: { class: 'ej-pill', style: '--btn-fill: var(--ej-blue);' },
  twitter: { class: 'ej-pill ej-pill--ghost', style: undefined },
  email: { class: 'ej-pill', style: undefined },
};
---

<footer>
  <div class="inner">
    <span class="line">© {year} Ender Jones — still working.</span>
    <div class="pills">
      {socials.map((s) => (
        <a
          class={pillStyle[s.key].class}
          style={pillStyle[s.key].style}
          href={s.href}
          target={s.key === 'email' ? undefined : '_blank'}
          rel={s.key === 'email' ? undefined : 'noopener'}
        >{s.label}</a>
      ))}
    </div>
  </div>
</footer>

<style>
  footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 26px 40px;
  }
  .line {
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-label);
  }
  .pills {
    display: flex;
    gap: 10px;
  }
  @media (max-width: 720px) {
    .inner {
      padding: 26px 20px;
    }
  }
  @media (max-width: 560px) {
    /* 版权行被右侧胶囊挤成三行 → 上下堆叠: 版权整宽一行, 链接落下面 */
    .inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
  }
</style>
