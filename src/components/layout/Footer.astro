---
const year = new Date().getFullYear();
---

<footer>
  <div class="inner">
    <span class="line">© {year} Ender Jones — still working.</span>
    <div class="pills">
      <a class="ej-pill" style="--btn-fill: var(--ej-blue);" href="https://github.com/Ender-Jones" target="_blank" rel="noopener">GitHub</a>
      <a class="ej-pill ej-pill--ghost" href="https://x.com/EnderJones1872" target="_blank" rel="noopener">X</a>
      <a class="ej-pill" href="mailto:enderjones1872@gmail.com">Email</a>
    </div>
  </div>
</footer>

<style>
  footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 26px 40px;
  }
  .line {
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: 11.5px;
  }
  .pills {
    display: flex;
    gap: 10px;
  }
  @media (max-width: 720px) {
    .inner {
      padding: 26px 20px;
    }
  }
</style>
