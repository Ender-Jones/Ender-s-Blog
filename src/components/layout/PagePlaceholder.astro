---
// 未施工页面的诚实占位: 一句话说明 + 回家链接. 正式设计好后整页替换.
interface Props {
  kicker: string;
  title: string;
  note: string;
}

const { kicker, title, note } = Astro.props;
---

<main>
  <section class="ph reveal" style="--reveal-i: 0;">
    <p class="kicker">{kicker}</p>
    <h1>{title}<span class="ej-caret" aria-hidden="true"></span></h1>
    <p class="note">{note}</p>
    <a class="home" href="/" data-route="→ / — home">← back to the notebook</a>
  </section>
</main>

<style>
  .ph {
    display: grid;
    align-content: center;
    gap: 0;
    min-height: calc(100vh - 46px - 160px);
    max-width: 640px;
  }
  .kicker {
    margin: 0 0 18px;
    color: #82828c;
    font-family: var(--ej-mono);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.24em;
  }
  h1 {
    margin: 0;
    color: var(--ej-text);
    font-family: var(--ej-serif);
    font-size: clamp(34px, 4vw, 50px);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.1;
  }
  .note {
    margin: 18px 0 0;
    color: var(--ej-text-3);
    font-family: var(--ej-serif);
    font-size: 16.5px;
    font-style: italic;
    font-weight: 300;
    line-height: 1.6;
    text-wrap: pretty;
  }
  .home {
    margin-top: 28px;
    justify-self: start;
    color: #9a9aa2;
    font-family: var(--ej-mono);
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    padding-bottom: 2px;
    transition: color 120ms var(--ej-ease);
  }
  .home:hover {
    color: var(--ej-text);
  }
</style>
