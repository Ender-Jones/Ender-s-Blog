---
// 字体三件套(V2 血统, 2026-07 拍板): Source Serif Pro(声音)/Noto Sans(阅读)/Fira Code(仪表盘).
// 中文自托管 Noto Sans SC — index 按 unicode-range 切片, 访客只下用到的分片(国内 100% 体验).
import '@fontsource/source-serif-pro/300.css';
import '@fontsource/source-serif-pro/300-italic.css';
import '@fontsource/source-serif-pro/index.css';
import '@fontsource/source-serif-pro/400-italic.css';
import '@fontsource/source-serif-pro/600.css';
import '@fontsource/noto-sans/index.css';
import '@fontsource/noto-sans/500.css';
import '@fontsource/noto-sans/600.css';
import '@fontsource/noto-sans-sc/400.css';
import '@fontsource/noto-sans-sc/500.css';
import '@fontsource/noto-sans-sc/600.css';
import '@fontsource-variable/fira-code/index.css';
import '../../styles/global.css';
import SiteBackdrop from './SiteBackdrop.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
  langAlt?: string;
  lang?: 'en' | 'zh';
  neutral?: boolean; // 语言中立页(worklog): 传给 Nav, 让它按读者偏好保留语言
}

const {
  title,
  description,
  noindex = false,
  ogImage = '/img/posts/whoami-dusk.jpg',
  langAlt,
  lang,
  neutral,
} = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const ogImageAbs = Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#030305" />
    {/* 站点只有一张脸: 图标全部出自 public/img/author/ang.JPG(与 Hero/About/console 同一张).
        照片做不了 SVG, 所以走 PNG + ico 后备; 换头像时四个尺寸一起重出. */}
    <link rel="icon" type="image/png" sizes="96x96" href="/assets/img/favicons/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicons/favicon-32x32.png" />
    <link rel="icon" href="/assets/img/favicons/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/assets/img/favicons/apple-touch-icon.png" />
  </head>
  <body>
    <SiteBackdrop />
    <Nav langAlt={langAlt} lang={lang} neutral={neutral} />
    <slot />
    <Footer />
  </body>
</html>
