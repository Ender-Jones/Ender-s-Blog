---
// 字体三件套(V2 血统, 2026-07 拍板): Source Serif Pro(声音)/Noto Sans(阅读)/Fira Code(仪表盘).
// 中文自托管 Noto Sans SC — index 按 unicode-range 切片, 访客只下用到的分片(国内 100% 体验).
import '@fontsource/source-serif-pro/300.css';
import '@fontsource/source-serif-pro/300-italic.css';
import '@fontsource/source-serif-pro/index.css';
import '@fontsource/source-serif-pro/400-italic.css';
import '@fontsource/source-serif-pro/600.css';
import '@fontsource/noto-sans/index.css';
import '@fontsource/noto-sans/500.css';
import '@fontsource/noto-sans/600.css';
import '@fontsource/noto-sans-sc/400.css';
import '@fontsource/noto-sans-sc/500.css';
import '@fontsource/noto-sans-sc/600.css';
import '@fontsource-variable/fira-code/index.css';
import '../../styles/global.css';
import SiteBackdrop from './SiteBackdrop.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}

const { title, description, noindex = false, ogImage = '/img/posts/whoami-dusk.jpg' } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const ogImageAbs = Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#030305" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/assets/img/favicons/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/assets/img/favicons/apple-touch-icon.png" />
  </head>
  <body>
    <SiteBackdrop />
    <Nav />
    <slot />
    <Footer />
  </body>
</html>
