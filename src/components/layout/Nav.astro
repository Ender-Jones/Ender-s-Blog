---
// tone = 悬停/激活的语义色: 作品与人=粉(公开/活着), worklog=琥珀(today/next 的家), research=蓝(信号/数据)
const links = [
  { label: 'Writing', href: '/posts/', route: '→ /posts/', tone: 'pink' },
  { label: 'Worklog', href: '/worklog/', route: '→ /worklog/', tone: 'amber' },
  { label: 'Research', href: '/research/', route: '→ /research/', tone: 'blue' },
  { label: 'About', href: '/about/', route: '→ /about/', tone: 'pink' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href);
const isZh = path === '/zh/' || path.startsWith('/zh/');
---

<nav>
  <div class="inner">
    <a class="logo" href="/" data-route="→ / — home">
      <span class="name">Ender Jones</span>
      <span class="caret" aria-hidden="true"></span>
    </a>
    <div class="right">
      {links.map((l) => (
        <a class:list={['link', `tone-${l.tone}`, { active: isActive(l.href) }]} href={l.href} data-route={l.route}>{l.label}</a>
      ))}
      <span class="divider" aria-hidden="true"></span>
      <span class="lang">
        <a class:list={['lang-a', { on: !isZh }]} href="/" data-route="→ / — english">EN</a>
        <a class:list={['lang-a', { on: isZh }]} href="/zh/" data-route="→ /zh/ — 中文(施工中)">中</a>
      </span>
    </div>
  </div>
</nav>

<style>
  nav {
    view-transition-name: site-nav;
    position: sticky;
    top: 0;
    z-index: 40;
    /* 更实的底色扛可读性(内容从下面滚过时不糊字), 模糊保持轻(较少) */
    background: rgba(4, 4, 7, 0.72);
    backdrop-filter: blur(5px) saturate(1.15);
    -webkit-backdrop-filter: blur(5px) saturate(1.15);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 14px 34px -22px rgba(0, 0, 0, 0.85);
  }
  .inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    height: 46px;
    padding: 0 40px;
  }
  .logo {
    display: flex;
    align-items: baseline;
    gap: 7px;
    text-decoration: none;
  }
  .name {
    color: var(--ej-text);
    font-family: var(--ej-serif);
    font-size: 18px;
    font-style: italic;
    font-weight: var(--ej-fw-medium);
    letter-spacing: 0.005em;
  }
  .caret {
    display: inline-block;
    width: 9px;
    height: 2px;
    border-radius: 1px;
    background: var(--ej-pink);
    box-shadow:
      0 0 8px rgba(255, 122, 192, 0.8),
      0 0 20px rgba(255, 122, 192, 0.35);
    animation: ej-caret 1.3s linear infinite;
  }
  .right {
    display: flex;
    align-items: center;
    gap: 26px;
  }
  .link {
    --t: var(--ej-pink-2);
    --t-rgb: 255, 122, 192;
    color: var(--ej-text-3);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-small);
    font-weight: var(--ej-fw-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding-bottom: 3px;
    border-bottom: 2px solid transparent;
    transition: color 120ms var(--ej-ease);
  }
  .link.tone-amber {
    --t: var(--ej-amber-2);
    --t-rgb: 245, 158, 11;
  }
  .link.tone-blue {
    --t: var(--ej-blue-2);
    --t-rgb: 76, 194, 255;
  }
  .link:hover {
    color: var(--t);
    text-shadow: 0 0 12px rgba(var(--t-rgb), 0.45);
  }
  .link.active {
    color: var(--ej-text);
    border-bottom-color: rgba(var(--t-rgb), 0.55);
    text-shadow: none;
  }
  .divider {
    width: 1px;
    height: 15px;
    background: rgba(255, 255, 255, 0.12);
  }
  .lang {
    display: inline-flex;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    padding: 2px;
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-meta);
    background: rgba(0, 0, 0, 0.25);
  }
  .lang-a {
    padding: 3px 9px;
    border-radius: 999px;
    color: var(--ej-mut-2);
    text-decoration: none;
    transition: color 120ms ease;
  }
  .lang-a:hover {
    color: var(--ej-text);
  }
  .lang-a.on {
    background: rgba(255, 255, 255, 0.08);
    color: var(--ej-text);
  }
  @media (max-width: 720px) {
    .inner {
      padding: 0 20px;
    }
    .right {
      gap: 14px;
    }
  }
  @media (max-width: 560px) {
    /* EN/中 还是视觉占位, 移动端先让位给导航本体 */
    .divider,
    .lang {
      display: none;
    }
    .right {
      gap: 12px;
    }
    .link {
      font-size: var(--ej-fs-label);
      letter-spacing: 0.05em;
    }
    .name {
      font-size: 16px;
    }
  }
</style>
