---
const links = [
  { label: 'Writing', href: '/posts/', route: '→ /posts/' },
  { label: 'Worklog', href: '/worklog/', route: '→ /worklog/' },
  { label: 'Research', href: '/research/', route: '→ /research/' },
  { label: 'About', href: '/about/', route: '→ /about/' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href);
---

<nav>
  <div class="inner">
    <span class="fade-accent" aria-hidden="true"></span>
    <a class="logo" href="/" data-route="→ / — home">
      <span class="name">Ender Jones</span>
      <span class="caret" aria-hidden="true"></span>
      <span class="suffix">research notebook</span>
    </a>
    <div class="right">
      {links.map((l) => (
        <a class:list={['link', { active: isActive(l.href) }]} href={l.href} data-route={l.route}>{l.label}</a>
      ))}
      <span class="divider" aria-hidden="true"></span>
      <span class="lang" title="中文版 — planned">
        <span class="lang-on">EN</span>
        <span class="lang-off" data-route="中文版 — planned">中</span>
      </span>
    </div>
  </div>
</nav>

<style>
  nav {
    view-transition-name: site-nav;
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(4, 4, 7, 0.5);
    backdrop-filter: blur(9px) saturate(1.4);
    -webkit-backdrop-filter: blur(9px) saturate(1.4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 14px 34px -22px rgba(0, 0, 0, 0.85);
  }
  .inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    height: 46px;
    padding: 0 40px;
  }
  .fade-accent {
    position: absolute;
    bottom: -1px;
    left: 40px;
    width: 210px;
    height: 1px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.3), transparent);
    pointer-events: none;
  }
  .logo {
    display: flex;
    align-items: baseline;
    gap: 7px;
    text-decoration: none;
  }
  .name {
    color: var(--ej-text);
    font-family: var(--ej-serif);
    font-size: 18px;
    font-style: italic;
    font-weight: 500;
    letter-spacing: 0.005em;
  }
  .caret {
    display: inline-block;
    width: 9px;
    height: 2px;
    border-radius: 1px;
    background: var(--ej-pink);
    box-shadow:
      0 0 8px rgba(255, 122, 192, 0.8),
      0 0 20px rgba(255, 122, 192, 0.35);
    animation: ej-caret 1.3s linear infinite;
  }
  .suffix {
    margin-left: 7px;
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: 11px;
  }
  .right {
    display: flex;
    align-items: center;
    gap: 26px;
  }
  .link {
    color: var(--ej-text-3);
    font-family: var(--ej-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding-bottom: 3px;
    border-bottom: 2px solid transparent;
    transition: color 120ms var(--ej-ease);
  }
  .link:hover {
    color: var(--ej-text);
  }
  .link.active {
    color: var(--ej-text);
    border-bottom-color: rgba(255, 122, 192, 0.55);
  }
  .divider {
    width: 1px;
    height: 15px;
    background: rgba(255, 255, 255, 0.12);
  }
  .lang {
    display: inline-flex;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    padding: 2px;
    font-family: var(--ej-mono);
    font-size: 10px;
    background: rgba(0, 0, 0, 0.25);
  }
  .lang-on {
    padding: 3px 9px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    color: var(--ej-text);
  }
  .lang-off {
    padding: 3px 9px;
    border-radius: 999px;
    color: var(--ej-mut-2);
    cursor: pointer;
    transition: color 120ms ease;
  }
  .lang-off:hover {
    color: var(--ej-text);
  }
  @media (max-width: 720px) {
    .inner {
      padding: 0 20px;
    }
    .fade-accent {
      left: 20px;
    }
    .suffix {
      display: none;
    }
    .right {
      gap: 14px;
    }
  }
  @media (max-width: 560px) {
    /* EN/中 还是视觉占位, 移动端先让位给导航本体 */
    .divider,
    .lang {
      display: none;
    }
    .right {
      gap: 12px;
    }
    .link {
      font-size: 11px;
      letter-spacing: 0.05em;
    }
    .name {
      font-size: 16px;
    }
  }
</style>
