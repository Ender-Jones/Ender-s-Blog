---
// tone = 悬停/激活的语义色: 作品与人=粉(公开/活着), worklog=琥珀(today/next 的家), research=蓝(信号/数据)
const links = [
  { label: 'Writing', href: '/posts/', route: '→ /posts/', tone: 'pink' },
  { label: 'Worklog', href: '/worklog/', route: '→ /worklog/', tone: 'amber' },
  { label: 'Research', href: '/research/', route: '→ /research/', tone: 'blue' },
  { label: 'About', href: '/about/', route: '→ /about/', tone: 'pink' },
];
// langAlt = 本页译文的 URL(文章页传 i18n_alt), lang = 本页语言(文章页传 frontmatter).
// 有了它, 语言开关就上下文感知: 在有译文的文章上点"中"→ 去这篇的中文版, 而非 /zh/ 着陆页.
interface Props {
  langAlt?: string;
  lang?: 'en' | 'zh';
}
const { langAlt, lang } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href);
// zh 文章在 /posts/zh/ 下, 不带 /zh/ 前缀 → 语言要由 frontmatter 显式给, 着陆页才靠路径推断
const curLang = lang ?? (path === '/zh/' || path.startsWith('/zh/') ? 'zh' : 'en');
const isZh = curLang === 'zh';
// 单一动作钮: 永远只显示"另一种语言", 点了必切 — 状态展示式双钮会出现"点当前语言=白刷新"
const altHref = isZh ? (langAlt ?? '/') : (langAlt ?? '/zh/');
---

<nav>
  <div class="inner">
    <a class="logo" href="/" data-route="→ / — home">
      <span class="name">Ender Jones</span>
      <span class="caret" aria-hidden="true"></span>
    </a>
    <div class="right">
      {links.map((l) => (
        <a class:list={['link', `tone-${l.tone}`, { active: isActive(l.href) }]} href={l.href} data-route={l.route}>{l.label}</a>
      ))}
      <span class="divider" aria-hidden="true"></span>
      <a class="lang-a" href={altHref} data-route={isZh ? '→ english' : '→ 中文'}>{isZh ? 'EN' : '中'}</a>
    </div>
  </div>
</nav>

<style>
  nav {
    view-transition-name: site-nav;
    position: sticky;
    top: 0;
    z-index: 40;
    /* 更实的底色扛可读性(内容从下面滚过时不糊字), 模糊保持轻(较少).
       ⚠ 只写标准 backdrop-filter — 手写 -webkit- 会让 CSS 压缩器只留 -webkit- 版,
       而 Chrome 不认 -webkit-backdrop-filter → 线上(压缩后)不糊(dev 不压缩才糊). 压缩器会自动补前缀. */
    background: rgba(4, 4, 7, 0.72);
    backdrop-filter: blur(3px) saturate(0.9);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 14px 34px -22px rgba(0, 0, 0, 0.85);
  }
  /* 兜底: 画不出毛玻璃的浏览器(极老 / 不认标准 backdrop-filter)→ 底色加深保可读 */
  @supports not (backdrop-filter: blur(1px)) {
    nav {
      background: rgba(4, 4, 7, 0.9);
    }
  }
  .inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    height: 46px;
    padding: 0 40px;
  }
  .logo {
    display: flex;
    padding-block: 3px; /* 命中高度 ≥24px(窄屏 wordmark 缩小后也够), 负 margin 抵消 */
    margin-block: -3px;
    align-items: baseline;
    gap: 7px;
    text-decoration: none;
  }
  .name {
    color: var(--ej-text);
    font-family: var(--ej-serif);
    font-size: 18px;
    font-style: italic;
    font-weight: var(--ej-fw-body); /* serif 无 500, medium 实渲染就是 400 — 写诚实值 */
    letter-spacing: 0.005em;
    white-space: nowrap; /* 窄屏下 wordmark 折行会把 caret 挤去撞导航链接 */
  }
  .caret {
    display: inline-block;
    width: 9px;
    height: 2px;
    border-radius: 1px;
    background: var(--ej-pink);
    box-shadow:
      0 0 8px rgba(255, 122, 192, 0.8),
      0 0 20px rgba(255, 122, 192, 0.35);
    animation: ej-caret 1.3s linear infinite;
  }
  .right {
    display: flex;
    align-items: center;
    gap: 26px;
  }
  .link {
    /* hover = tone pill 背景亮起(动态); active 仍是底部 tone 细边框(不变) */
    --t: var(--ej-pink-2);
    --t-rgb: 255, 122, 192;
    padding: 4px 10px 3px;
    border-radius: 7px;
    border-bottom: 2px solid transparent;
    color: var(--ej-text-3);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-small);
    font-weight: var(--ej-fw-medium);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 120ms var(--ej-ease);
  }
  .link.tone-amber {
    --t: var(--ej-amber-2);
    --t-rgb: 245, 158, 11;
  }
  .link.tone-blue {
    --t: var(--ej-blue-2);
    --t-rgb: 76, 194, 255;
  }
  .link:hover {
    color: var(--t);
    background: rgba(var(--t-rgb), 0.1);
  }
  .link.active {
    color: var(--ej-text);
    border-bottom-color: rgba(var(--t-rgb), 0.55);
  }
  .divider {
    width: 1px;
    height: 15px;
    background: rgba(255, 255, 255, 0.12);
  }
  .lang-a {
    padding: 4px 10px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.25);
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-meta);
    text-decoration: none;
    transition: all 120ms ease;
  }
  .lang-a:hover {
    color: var(--ej-text);
    border-color: rgba(255, 255, 255, 0.32);
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-1px);
  }
  /* 中性色填充(语言切换无专属语义色, 不套四色); 抬起→按下给物理动作感 */
  .lang-a:active {
    transform: translateY(0);
  }
  @media (max-width: 720px) {
    .inner {
      padding: 0 20px;
    }
    .right {
      gap: 14px;
    }
  }
  @media (max-width: 560px) {
    .divider {
      display: none;
    }
    .right {
      gap: 10px;
    }
    .link {
      padding: 4px 6px; /* pill padding 收窄, 腾出横向空间 */
      font-size: var(--ej-fs-micro);
      letter-spacing: 0.04em;
    }
    .name {
      font-size: 16px;
    }
    .lang-a {
      padding: 4px 9px;
    }
  }
  @media (max-width: 430px) {
    /* 375px 一行装下 wordmark + 四链接 + 语言开关: 全员再收一档 */
    .inner {
      padding: 0 14px;
    }
    .right {
      gap: 8px;
    }
    .link {
      padding: 4px 0; /* 极窄屏取消 pill 左右 padding, 恢复原布局余量(触屏无 hover) */
      letter-spacing: 0.01em;
    }
    .name {
      font-size: 14px;
    }
    .lang-a {
      padding: 4px 7px;
    }
  }
</style>
