---
// 暗房底层: 56px 微网格 + 六枚异速漂移光点, 均以慢于内容的速度视差.
---

<div class="grid" data-parallax="0.05" aria-hidden="true"></div>
<span class="dot dot-a" data-parallax="0.10" aria-hidden="true"><span></span></span>
<span class="dot dot-b" data-parallax="0.06" aria-hidden="true"><span></span></span>
<span class="dot dot-c" data-parallax="0.14" aria-hidden="true"><span></span></span>
<span class="dot dot-d" data-parallax="0.08" aria-hidden="true"><span></span></span>
<span class="dot dot-e" data-parallax="0.12" aria-hidden="true"><span></span></span>
<span class="dot dot-f" data-parallax="0.07" aria-hidden="true"><span></span></span>

<style>
  .grid {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.019) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.019) 1px, transparent 1px);
    background-size: 56px 56px;
  }
  .dot {
    position: fixed;
    z-index: 0;
    pointer-events: none;
  }
  .dot > span {
    display: block;
    border-radius: 999px;
  }
  .dot-a {
    top: 18%;
    left: 12%;
  }
  .dot-a > span {
    width: 4px;
    height: 4px;
    background: var(--ej-pink);
    opacity: 0.39;
    filter: blur(1.5px);
    box-shadow: 0 0 11px rgba(255, 122, 192, 0.6);
    animation: ej-drift-a 34s ease-in-out infinite;
  }
  .dot-b {
    top: 52%;
    right: 10%;
  }
  .dot-b > span {
    width: 3px;
    height: 3px;
    background: var(--ej-blue);
    opacity: 0.34;
    filter: blur(1px);
    box-shadow: 0 0 10px rgba(76, 194, 255, 0.54);
    animation: ej-drift-b 42s ease-in-out infinite;
  }
  .dot-c {
    bottom: 16%;
    left: 44%;
  }
  .dot-c > span {
    width: 3px;
    height: 3px;
    background: #e4e4e7;
    opacity: 0.24;
    filter: blur(1px);
    animation: ej-drift-c 28s ease-in-out infinite;
  }
  .dot-d {
    top: 72%;
    left: 18%;
  }
  .dot-d > span {
    width: 3px;
    height: 3px;
    background: var(--ej-pink);
    opacity: 0.27;
    filter: blur(1px);
    box-shadow: 0 0 9px rgba(255, 122, 192, 0.44);
    animation: ej-drift-b 48s ease-in-out infinite;
  }
  .dot-e {
    top: 10%;
    right: 28%;
  }
  .dot-e > span {
    width: 3px;
    height: 3px;
    background: var(--ej-blue);
    opacity: 0.25;
    filter: blur(1px);
    box-shadow: 0 0 8px rgba(76, 194, 255, 0.38);
    animation: ej-drift-c 40s ease-in-out infinite;
  }
  /* f 补右下空档(a-e 偏左上与中带), 参数沿用既有梯度不新增亮度档 */
  .dot-f {
    bottom: 28%;
    right: 22%;
  }
  .dot-f > span {
    width: 3px;
    height: 3px;
    background: #e4e4e7;
    opacity: 0.22;
    filter: blur(1px);
    animation: ej-drift-a 46s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .dot > span {
      animation: none;
    }
  }
</style>

<script>
  // 通用视差: 任何带 data-parallax 的元素都会被驱动(页面自己的氛围元素也能搭车).
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduced) {
    const els = [...document.querySelectorAll<HTMLElement>('[data-parallax]')];
    let raf = 0;
    const apply = () => {
      raf = 0;
      const sy = window.scrollY || 0;
      for (const el of els) {
        const k = Number(el.dataset.parallax || 0);
        if (el.classList.contains('grid')) {
          el.style.backgroundPosition = `0px ${-(sy * k).toFixed(1)}px`;
        } else {
          el.style.transform = `translate3d(0, ${-(sy * k).toFixed(1)}px, 0)`;
        }
      }
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!raf) raf = requestAnimationFrame(apply);
      },
      { passive: true },
    );
  }
</script>
