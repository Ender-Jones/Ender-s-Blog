---
// 周分组渲染: WEEK 标签 + OPEN 徽章 + 日期范围 + 自动 digest; 日行 = 星期/能量格 + 彩色符号条目 + 公开句.
import type { WorklogWeek, WorklogItemType } from '../../lib/worklogDays';

interface Props {
  weeks: WorklogWeek[];
}

const { weeks } = Astro.props;

const GLYPH: Record<WorklogItemType, { g: string; cls: string }> = {
  done: { g: '✓', cls: 'g-done' },
  decision: { g: '=', cls: 'g-decision' },
  risk: { g: '!', cls: 'g-risk' },
  next: { g: '>', cls: 'g-next' },
  dropped: { g: '~', cls: 'g-dropped' },
  wip: { g: '@', cls: 'g-wip' },
  note: { g: '·', cls: 'g-note' },
};

const plural = (n: number, s: string) => `${n} ${s}${n === 1 ? '' : 's'}`;

const digestOf = (week: WorklogWeek) => {
  const counts: Record<string, number> = {};
  for (const day of week.days)
    for (const item of day.items) counts[item.type] = (counts[item.type] ?? 0) + 1;
  const parts: string[] = [];
  if (counts.done) parts.push(`${counts.done} done`);
  if (counts.decision) parts.push(plural(counts.decision, 'decision'));
  if (counts.risk) parts.push(plural(counts.risk, 'risk'));
  if (counts.dropped) parts.push(`${counts.dropped} dropped`);
  const head = parts.length ? parts.join(' · ') : `${week.days.length} day${week.days.length === 1 ? '' : 's'} logged`;
  return `${head} — ${week.days.length}/7 days`;
};

const wdOf = (iso: string) => {
  const d = new Date(`${iso}T12:00:00Z`);
  const wd = d.toLocaleDateString('en-US', { weekday: 'short', timeZone: 'UTC' }).toUpperCase();
  return `${wd} ${iso.slice(5, 7)}·${iso.slice(8, 10)}`;
};
---

<div class="weeks">
  {weeks.map((w) => (
    <div class="week">
      <div class="week-head">
        <span class="wk">WEEK {w.week}</span>
        {w.current && <span class="open">OPEN</span>}
        <span class="range">{w.range}</span>
        <span class="rule" aria-hidden="true"></span>
        <span class="digest">{digestOf(w)}</span>
      </div>
      {w.days.map((d) => (
        <div class="day">
          <div class="day-side">
            <span class="wd">{wdOf(d.date)}</span>
            {d.energy && (
              <span class="energy" title={`energy ${d.energy}/5`}>
                {[1, 2, 3, 4, 5].map((i) => (
                  <span class:list={['e-cell', { on: i <= (d.energy ?? 0) }]}></span>
                ))}
              </span>
            )}
          </div>
          <div class="day-body">
            {d.items.map((item) => (
              <span class="entry">
                <span class:list={['glyph', GLYPH[item.type].cls]}>{GLYPH[item.type].g}</span>
                <span class:list={['text', { dropped: item.type === 'dropped', dim: item.type === 'wip' || item.type === 'note' }]}>{item.text}</span>
              </span>
            ))}
            {d.publicLine && (
              <span class="public">
                <span class="p-dot-wrap" aria-hidden="true"><span class="p-dot"></span></span>
                <span class="p-text">{d.publicLine}</span>
              </span>
            )}
          </div>
        </div>
      ))}
    </div>
  ))}
</div>

<style>
  .week {
    margin: 0 0 52px;
  }
  .week-head {
    display: flex;
    align-items: baseline;
    gap: 13px;
    margin: 0 0 6px;
  }
  .wk {
    color: var(--ej-text-2);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-label);
    font-weight: var(--ej-fw-head);
    letter-spacing: 0.18em;
  }
  .open {
    padding: 1px 7px;
    border: 1px solid rgba(245, 158, 11, 0.4);
    border-radius: 4px;
    color: var(--ej-amber-2);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-micro);
    font-weight: var(--ej-fw-head);
    letter-spacing: var(--ej-track-key);
  }
  .range {
    color: var(--ej-dim);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-meta);
    font-weight: var(--ej-fw-medium);
  }
  .rule {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.055);
    transform: translateY(-3px);
  }
  .digest {
    color: var(--ej-mut);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-meta);
    font-weight: var(--ej-fw-medium);
  }

  .day {
    display: grid;
    grid-template-columns: 118px minmax(0, 1fr);
    gap: 24px;
    padding: 17px 6px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.045);
    border-radius: 6px 6px 0 0;
    transition: background 180ms ease;
  }
  .day:hover {
    background: rgba(255, 255, 255, 0.012);
  }
  .day-side {
    display: grid;
    gap: 8px;
    align-content: start;
  }
  .wd {
    color: #9a9aa2;
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-label);
    font-weight: var(--ej-fw-medium);
    letter-spacing: 0.06em;
  }
  .energy {
    display: flex;
    gap: 3px;
  }
  .e-cell {
    width: 5px;
    height: 5px;
    border-radius: 1.5px;
    background: rgba(255, 255, 255, 0.06);
  }
  .e-cell.on {
    background: rgba(245, 158, 11, 0.55);
  }

  .day-body {
    display: grid;
    gap: 7px;
    align-content: start;
  }
  .entry {
    display: flex;
    align-items: baseline;
    gap: 11px;
  }
  .glyph {
    flex-shrink: 0;
    width: 14px;
    text-align: center;
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-label);
    font-weight: var(--ej-fw-head);
  }
  .g-done { color: #e8e8ea; }
  .g-decision { color: var(--ej-blue-2); }
  .g-risk { color: var(--ej-rose); }
  .g-next {
    color: var(--ej-amber-2);
    text-shadow: 0 0 8px rgba(245, 158, 11, 0.35);
  }
  .g-dropped { color: var(--ej-mut-2); }
  .g-wip { color: var(--ej-mut-2); }
  .g-note { color: var(--ej-mut-2); }
  .text {
    color: #c2c2c9;
    font-size: var(--ej-fs-note);
    line-height: 1.55;
    min-width: 0;
    overflow-wrap: break-word;
  }
  .text.dropped {
    color: var(--ej-mut-2);
    text-decoration: line-through;
    text-decoration-color: rgba(255, 255, 255, 0.3);
  }
  .text.dim {
    color: var(--ej-mut);
  }
  .public {
    display: flex;
    align-items: baseline;
    gap: 11px;
    margin-top: 3px;
  }
  .p-dot-wrap {
    flex-shrink: 0;
    width: 14px;
    display: grid;
    justify-items: center;
  }
  .p-dot {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--ej-pink);
    box-shadow: 0 0 6px rgba(255, 122, 192, 0.7);
    transform: translateY(-2px);
  }
  .p-text {
    color: #b9b9c2;
    font-family: var(--ej-serif);
    font-size: var(--ej-fs-body);
    font-style: italic;
    font-weight: var(--ej-fw-light);
    line-height: 1.5;
  }

  @media (max-width: 720px) {
    .day {
      grid-template-columns: 1fr;
      gap: 10px;
    }
    .day-side {
      display: flex;
      align-items: center;
      gap: 10px;
    }
  }
</style>
