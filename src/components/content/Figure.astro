---
// 文中插图: 圆角 + 发丝边 + 深阴影; size/align 控制排布, caption 为 mono 小字.
type Props = {
  src: string;
  alt: string;
  size?: 'default' | 'half' | 'wide' | 'full';
  align?: 'center' | 'left' | 'right';
  width?: number;
  height?: number;
  caption?: string;
};

const { src, alt, size = 'default', align = 'center', width, height, caption } = Astro.props;
---

<figure class:list={['figure', `size-${size}`, `align-${align}`]}>
  <img src={src} alt={alt} width={width} height={height} loading="lazy" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .figure {
    display: block;
    clear: both;
    width: min(100%, 680px);
    margin: 26px auto;
  }
  .size-half {
    width: min(50%, 520px);
  }
  .size-wide {
    width: min(80%, 820px);
  }
  .size-full {
    width: 100%;
  }
  .align-right {
    clear: right;
    float: right;
    margin: 6px 0 18px 26px;
  }
  .align-left {
    clear: left;
    float: left;
    margin: 6px 26px 18px 0;
  }
  img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.7),
      0 18px 44px -22px rgba(0, 0, 0, 0.95);
  }
  figcaption {
    margin-top: 9px;
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-meta);
    font-weight: var(--ej-fw-medium);
    line-height: 1.5;
  }
  @media (max-width: 720px) {
    .figure,
    .size-half,
    .size-wide,
    .size-full,
    .align-right,
    .align-left {
      float: none;
      width: 100%;
      margin: 20px 0;
    }
  }
</style>
