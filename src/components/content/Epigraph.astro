---
// 文章开篇引文: 原文(衬线斜体) → 译文(无衬线, 直接可见) → 出典行(短横线 + mono + 语言 chip).
// 原文与译文行数一致时逐行交错(原文在上, 译文压暗紧贴其下); 行数不一致则译文整块跟在后面.
type Props = {
  lines: string[];
  source?: string;
  translationLines?: string[];
  translationLabel?: string; // 兼容旧用法, 不再渲染(译文常显)
  lang?: string;
};

const { lines, source, translationLines = [], lang } = Astro.props;
const interleaved = translationLines.length > 0 && translationLines.length === lines.length;
---

<blockquote class="epigraph">
  <span class="bar" aria-hidden="true"></span>
  {interleaved ? (
    <div class="original">
      {lines.map((line, i) =>
        line ? (
          <span class="pair">
            <span>{line}</span>
            {translationLines[i] && <span class="pair-trans">{translationLines[i]}</span>}
          </span>
        ) : (
          <span class="stanza-gap" aria-hidden="true"></span>
        ),
      )}
    </div>
  ) : (
    <div class="original">
      {lines.map((line) => <span>{line}</span>)}
    </div>
  )}
  {!interleaved && translationLines.length > 0 && (
    <div class="translation">
      {translationLines.map((line) => <span>{line}</span>)}
    </div>
  )}
  {source && (
    <footer>
      <span class="rule" aria-hidden="true"></span>
      <span class="source">{source}</span>
      {lang && <span class="lang">{lang.toUpperCase()}</span>}
    </footer>
  )}
</blockquote>

<style>
  .epigraph {
    position: relative;
    margin: 6px 0 46px;
    padding: 2px 0 2px 26px;
  }
  .bar {
    position: absolute;
    left: 0;
    top: 2px;
    bottom: 2px;
    width: 2px;
    border-radius: 2px;
    background: linear-gradient(180deg, rgba(255, 122, 192, 0.55), rgba(255, 122, 192, 0.06));
  }
  .original {
    display: grid;
    color: #d6d6db;
    font-family: var(--ej-serif);
    font-size: 17.5px;
    font-style: italic;
    font-weight: var(--ej-fw-body); /* 300 只许 ≥20px 展示尺寸 */
    line-height: var(--ej-lh-loose);
    text-wrap: pretty;
  }
  .original span {
    display: block;
  }
  .pair {
    margin: 0 0 11px;
  }
  .pair:last-child {
    margin-bottom: 0;
  }
  .pair-trans {
    margin-top: 1px;
    color: var(--ej-mut);
    font-family: var(--ej-sans);
    font-size: var(--ej-fs-note);
    font-style: normal;
    font-weight: var(--ej-fw-body);
    line-height: 1.5;
  }
  .stanza-gap {
    height: 10px;
  }
  .translation {
    display: grid;
    margin-top: 9px;
    max-width: 58ch;
    color: var(--ej-mut);
    font-family: var(--ej-sans);
    font-size: var(--ej-fs-note);
    font-weight: var(--ej-fw-body);
    line-height: 1.65;
  }
  .translation span {
    display: block;
  }
  footer {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 14px;
  }
  .rule {
    width: 18px;
    height: 1px;
    background: rgba(255, 255, 255, 0.22);
  }
  .source {
    color: var(--ej-mut);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-meta);
    font-weight: var(--ej-fw-medium);
    letter-spacing: var(--ej-track-chip);
  }
  .lang {
    padding: 1px 6px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    color: var(--ej-dim);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-micro);
    font-weight: var(--ej-fw-head);
    letter-spacing: var(--ej-track-key);
  }
  @media (max-width: 720px) {
    .epigraph {
      padding-left: 18px;
    }
  }
</style>
