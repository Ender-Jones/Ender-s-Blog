---
// 诗: 居中衬线斜体, 行距宽, 结语引号收束.
type Props = {
  title: string;
  lines: string[];
  closing?: string;
};

const { title, lines, closing } = Astro.props;
---

<div class="poem">
  <h2>{title}</h2>
  <p class="verse">
    {lines.map((line) => <span>{line}</span>)}
  </p>
  {closing && <p class="closing">“{closing}”</p>}
</div>

<style>
  .poem {
    width: max-content;
    max-width: 100%;
    margin: 34px auto 42px;
    color: var(--ej-text-2);
    font-family: var(--ej-serif);
    font-size: 18px;
    font-style: italic;
    font-weight: 300;
    line-height: 1.9;
    text-align: center;
  }
  h2 {
    margin: 0 0 44px;
    color: var(--ej-text);
    font-family: var(--ej-serif);
    font-size: 22px;
    font-style: normal;
    font-weight: 400;
    line-height: 1.4;
    text-align: center;
  }
  .verse {
    margin: 0;
    white-space: nowrap;
  }
  .verse span {
    display: block;
  }
  .closing {
    margin: 20px 0 0;
    color: var(--ej-text-3);
  }
  @media (max-width: 720px) {
    .poem {
      width: auto;
      font-size: var(--ej-fs-lede);
    }
    .verse {
      white-space: normal;
    }
  }
</style>
