---
// 文中提示块: 安静面板 + 彩点 + mono 标签 + 渐隐发丝线.
// 语义色: info/note=蓝(信号) · tip/warning=琥珀(行动) · danger=玫瑰(风险).
type Props = {
  type?: 'info' | 'tip' | 'note' | 'warning' | 'danger';
  title?: string;
};

const labels = {
  info: 'Info',
  tip: 'Tip',
  note: 'Note',
  warning: 'Warning',
  danger: 'Danger',
};

const { type = 'info', title = labels[type] } = Astro.props;
const tone = type === 'tip' || type === 'warning' ? 'amber' : type === 'danger' ? 'rose' : 'blue';
---

<aside class:list={['callout', `tone-${tone}`]}>
  <span class="head">
    <span class="dot" aria-hidden="true"></span>
    <span class="label">{title}</span>
    <span class="hairline" aria-hidden="true"></span>
  </span>
  <div class="body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 24px 0;
    padding: 13px 17px 15px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 9px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.018), rgba(255, 255, 255, 0.005));
  }
  .head {
    display: flex;
    align-items: center;
    gap: 9px;
  }
  .dot {
    width: 4px;
    height: 4px;
    border-radius: 999px;
    background: var(--tone);
    box-shadow: 0 0 7px rgba(var(--tone-rgb), 0.85);
  }
  .label {
    color: var(--tone-2);
    font-family: var(--ej-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }
  .hairline {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(var(--tone-rgb), 0.16), transparent);
  }
  .body {
    display: grid;
    gap: 8px;
    color: #b4b4bc;
    font-size: 14.5px;
    line-height: 1.65;
  }
  .body :global(> *) {
    margin: 0;
  }
</style>
