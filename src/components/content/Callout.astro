---
type Props = {
  type?: 'info' | 'tip' | 'note' | 'warning' | 'danger';
  title?: string;
};

const labels = {
  info: 'Info',
  tip: 'Tip',
  note: 'Note',
  warning: 'Warning',
  danger: 'Danger',
};

const { type = 'info', title = labels[type] } = Astro.props;
---

<aside class:list={['content-callout', `content-callout--${type}`]}>
  <p class="content-callout__title">{title}</p>
  <div class="content-callout__body">
    <slot />
  </div>
</aside>

<style>
  .content-callout {
    position: relative;
    display: grid;
    gap: var(--s-3);
    margin: var(--s-8) 0;
    padding: var(--s-5) var(--s-6);
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-left: 4px solid var(--accent-blue);
    border-radius: var(--r-md);
    background:
      linear-gradient(90deg, rgba(56, 189, 248, 0.08), transparent 38%),
      rgba(14, 16, 20, 0.58);
  }

  .content-callout__title {
    margin: 0;
    color: var(--accent-blue);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: var(--fw-semibold);
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .content-callout__body {
    display: grid;
    gap: var(--s-3);
  }

  .content-callout__body :global(> *) {
    margin: 0;
  }

  .content-callout--tip {
    border-left-color: var(--accent-teal);
    background:
      linear-gradient(90deg, rgba(93, 202, 165, 0.09), transparent 38%),
      rgba(14, 16, 20, 0.58);
  }

  .content-callout--tip .content-callout__title {
    color: var(--accent-teal);
  }

  .content-callout--warning {
    border-left-color: #fbbf24;
    background:
      linear-gradient(90deg, rgba(251, 191, 36, 0.09), transparent 38%),
      rgba(14, 16, 20, 0.58);
  }

  .content-callout--warning .content-callout__title {
    color: #fbbf24;
  }

  .content-callout--danger {
    border-left-color: var(--accent-pink);
    background:
      linear-gradient(90deg, rgba(244, 114, 182, 0.1), transparent 38%),
      rgba(14, 16, 20, 0.58);
  }

  .content-callout--danger .content-callout__title {
    color: var(--accent-pink);
  }

  @media (max-width: 720px) {
    .content-callout {
      padding: var(--s-4);
    }
  }
</style>
