---
// §5 Coda: 随机引文 + ⟳ again(渐隐下沉 220ms 换一条). 引文库: src/data/quotes.yml.
// pinned_only 的条目(印自己的句子)不进随机池 — 只在固定它的文章末尾出现.
import { quotes } from '../../lib/data';

const pool = quotes.filter((q) => !q.pinned_only);
const first = pool[0];
// 已自带引号(« » 或 “ ”)的原文不再套一层. 注意: 正则不能直写在 {} 里 — JSX 会当成注释开头.
const firstText = /^[«“"]/.test(first.text) ? first.text : `“${first.text}”`;
---

<section class="reveal" style="--reveal-i: 4;" data-screen="coda">
  <div class="wrap">
    <blockquote id="coda-quote">{firstText}</blockquote>
    <p class="coda-trans" id="coda-trans">{first.trans ?? ''}</p>
    <div class="meta-row">
      <p class="source">— <span id="coda-source">{first.source}</span></p>
      <button id="coda-reroll" class="ej-orb" type="button" aria-label="another quote" data-route="⟳ another quote"
        ><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-2.64-6.36"/><path d="M21 3v6h-6"/></svg></button>
    </div>
  </div>
</section>

<script is:inline type="application/json" id="coda-data" set:html={JSON.stringify(pool)} />

<script is:inline>
  (function () {
    var data = document.getElementById('coda-data');
    var quote = document.getElementById('coda-quote');
    var trans = document.getElementById('coda-trans');
    var source = document.getElementById('coda-source');
    var btn = document.getElementById('coda-reroll');
    if (!data || !quote || !trans || !source || !btn) return;
    var quotes = JSON.parse(data.textContent || '[]');
    if (!quotes.length) return;
    // 已自带引号(« » 或 “ ”)的原文不再套一层
    var dress = function (t) {
      return /^[«“"]/.test(t) ? t : '“' + t + '”';
    };
    var qi = Math.floor(Math.random() * quotes.length);
    var fading = false;
    var show = function () {
      var q = quotes[qi];
      quote.textContent = dress(q.text);
      // 主页是英文页: 非英语原文配英译; 本来就是英语的条目没有 trans, 这行自然空着
      trans.textContent = q.trans || '';
      source.textContent = q.source;
    };
    show();
    btn.addEventListener('click', function () {
      if (quotes.length < 2 || fading) return;
      btn.classList.remove('spin');
      void btn.offsetWidth;
      btn.classList.add('spin');
      var n = Math.floor(Math.random() * (quotes.length - 1));
      if (n >= qi) n += 1;
      fading = true;
      quote.classList.add('fade');
      trans.classList.add('fade');
      source.parentElement.classList.add('fade');
      setTimeout(function () {
        qi = n;
        show();
        quote.classList.remove('fade');
        trans.classList.remove('fade');
        source.parentElement.classList.remove('fade');
        fading = false;
      }, 230);
    });
  })();
</script>

<style>
  .wrap {
    padding: clamp(72px, 11vh, 110px) 0 clamp(64px, 9vh, 90px);
    max-width: 820px;
  }
  blockquote {
    margin: 0;
    color: var(--ej-text-2);
    font-family: var(--ej-serif);
    font-size: clamp(22px, 2.4vw, 28px);
    font-style: italic;
    font-weight: var(--ej-fw-light);
    line-height: 1.42;
    text-wrap: pretty;
    min-height: 2.8em;
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 220ms ease,
      transform 260ms var(--ej-ease);
  }
  blockquote.fade {
    opacity: 0;
    transform: translateY(8px);
  }
  /* 译文行: 恒定高度预留(与 blockquote 一样), 换引文时不让下面的 meta 行跳动 */
  .coda-trans {
    margin: 12px 0 0;
    max-width: 58ch;
    min-height: 1.65em;
    color: var(--ej-mut);
    font-family: var(--ej-sans);
    font-size: var(--ej-fs-note);
    font-weight: var(--ej-fw-body);
    line-height: 1.65;
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 200ms ease,
      transform 260ms var(--ej-ease);
  }
  .coda-trans.fade {
    opacity: 0;
    transform: translateY(8px);
  }
  .meta-row {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 16px;
  }
  .source {
    margin: 0;
    color: var(--ej-mut);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-label);
    font-weight: var(--ej-fw-medium);
    opacity: 1;
    transition: opacity 200ms ease;
  }
  .source.fade {
    opacity: 0;
  }
  /* ⟳ 圆钮定位在行尾固定位置, 不随出处长短漂移 */
  #coda-reroll {
    margin-left: auto;
    flex-shrink: 0;
  }
</style>
