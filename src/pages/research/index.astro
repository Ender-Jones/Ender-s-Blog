---
// Research: 一条推进中的研究线 — thesis → 三站论文卡 → 方法与信号 → 指标 → 时间线+CV → next.
// 内容全部来自 src/data/research.yml 与 site.yml; CV 按钮仅当 public/cv.pdf 存在才渲染.
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import RouteHint from '../../components/home/RouteHint.astro';
import { research, site } from '../../lib/data';

const hasCv = existsSync(fileURLToPath(new URL('../../../public/cv.pdf', import.meta.url)));

const signalRows = [
  { key: 'signals', value: site.identity.signals.join(' · ') },
  { key: 'models', value: site.identity.models.join(' · ') },
  { key: 'stack', value: site.identity.tools.join(' · ') },
];
---

<BaseLayout title="Research — Ender Jones" description={research.focus} noindex>
  <RouteHint />
  <main style="--ej-page-w: 980px;">
    <section class="reveal" style="--reveal-i: 0;">
      <p class="kicker">RESEARCH — ONE LINE, IN MOTION</p>
      <h1>Research.<span class="caret" aria-hidden="true"></span></h1>
      <p class="thesis">{site.identity.thesis}</p>
      <p class="sub">{research.abstract}</p>
      <p class="tags">{research.tags.join(' · ')}</p>
    </section>

    <section class="papers reveal" style="--reveal-i: 1;">
      <div class="sec-head">
        <h2>The line <span class="sec-sub">{research.subtitle}</span></h2>
        <span class="sec-meta">{research.protocol}</span>
      </div>
      {research.papers.map((p) => (
        <article class:list={['paper', `tone-${p.tone}`]} id={p.anchor}>
          <span class="p-bar" aria-hidden="true"></span>
          <div class="p-status">
            <span class="p-dot" aria-hidden="true"></span>
            <span class="p-status-label">{p.status}</span>
            <span class="p-venue">{p.venue}</span>
          </div>
          <h3>{p.title}</h3>
          <p class="p-dek">{p.dek}</p>
          <p class="p-abstract">{p.abstract}</p>
          <div class="p-foot">
            <span class="p-contrib">{p.contribution}</span>
            <span class="p-links">
              {p.links.paper && <a href={p.links.paper} target="_blank" rel="noopener" data-route="↗ paper">paper ↗</a>}
              {p.links.code && <a href={p.links.code} target="_blank" rel="noopener" data-route="↗ code">code ↗</a>}
            </span>
          </div>
        </article>
      ))}
    </section>

    <section class="method reveal" style="--reveal-i: 2;">
      <div class="m-grid">
        <div class="m-card">
          <span class="m-label">Method &amp; signals</span>
          <div class="m-rows">
            {signalRows.map((row) => (
              <span class="m-row">
                <span class="m-key">{row.key}</span>
                <span class="m-lead" aria-hidden="true"></span>
                <span class="m-val">{row.value}</span>
              </span>
            ))}
          </div>
        </div>
        <div class="m-card m-metric">
          <span class="m-label"><span class="m-dot" aria-hidden="true"></span>{research.metric.label}</span>
          <span class="m-value">{research.metric.value}</span>
          <span class="m-note">{research.metric.notes.join(' · ')}</span>
          <p class="m-honesty">{research.metric.honesty}</p>
        </div>
      </div>
    </section>

    <section class="tl reveal" style="--reveal-i: 3;">
      <div class="sec-head">
        <h2>Timeline</h2>
        {hasCv && <a class="cv" href="/cv.pdf" data-route="↓ cv.pdf">download CV ↓</a>}
      </div>
      <div class="tl-list">
        {research.timeline.map((t) => (
          <div class:list={['tl-row', `tone-${t.tone}`]}>
            <span class="tl-when">{t.when}</span>
            <span class="tl-node" aria-hidden="true"></span>
            <span class="tl-label">{t.label}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="next reveal" style="--reveal-i: 4;">
      <div class="next-card">
        <span class="next-label">WHAT'S NEXT</span>
        <p class="next-text">{research.whats_next}</p>
        <a class="next-link" href="/worklog/" data-route="→ /worklog/ — the day-by-day version of this page">the day-by-day version of this page →</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .kicker {
    margin: 0 0 18px;
    padding-top: clamp(48px, 8vh, 76px);
    color: #82828c;
    font-family: var(--ej-mono);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.24em;
  }
  h1 {
    margin: 0;
    color: var(--ej-text);
    font-family: var(--ej-serif);
    font-size: clamp(38px, 4.6vw, 58px);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }
  .caret {
    display: inline-block;
    width: 0.5em;
    height: 0.07em;
    margin-left: 0.14em;
    border-radius: 1px;
    background: var(--ej-pink);
    box-shadow: 0 0 18px rgba(255, 122, 192, 0.55);
    animation: ej-caret 1.15s linear infinite;
  }
  .thesis {
    margin: 22px 0 0;
    max-width: 30ch;
    color: var(--ej-text-2);
    font-family: var(--ej-serif);
    font-size: clamp(20px, 2.2vw, 26px);
    font-style: italic;
    font-weight: 300;
    line-height: 1.45;
    text-wrap: balance;
  }
  .sub {
    margin: 16px 0 0;
    max-width: 62ch;
    color: var(--ej-text-3);
    font-size: 15px;
    line-height: 1.7;
    text-wrap: pretty;
  }
  .tags {
    margin: 14px 0 0;
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: 11.5px;
  }

  .sec-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  h2 {
    margin: 0;
    color: var(--ej-text);
    font-family: var(--ej-serif);
    font-size: 28px;
    font-weight: 400;
  }
  .sec-sub {
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: 11.5px;
    font-weight: 500;
    margin-left: 10px;
  }
  .sec-meta {
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: 11.5px;
    font-weight: 500;
  }

  .papers {
    padding: clamp(48px, 7vh, 68px) 0 0;
  }
  .paper {
    --tone: var(--ej-pink);
    --tone-rgb: 255, 122, 192;
    position: relative;
    padding: 22px 26px 20px 30px;
    margin-bottom: 12px;
    border: 1px solid rgba(255, 255, 255, 0.075);
    border-radius: 12px;
    background: linear-gradient(180deg, #0d0d10, #0a0a0c);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.7),
      0 16px 40px -20px rgba(0, 0, 0, 0.9),
      inset 0 1px 0 rgba(255, 255, 255, 0.055);
    scroll-margin-top: 84px;
    transition: border-color 180ms var(--ej-ease);
  }
  .paper.tone-blue {
    --tone: var(--ej-blue);
    --tone-rgb: 76, 194, 255;
  }
  .paper.tone-amber {
    --tone: var(--ej-amber);
    --tone-rgb: 245, 158, 11;
  }
  .paper:hover {
    border-color: rgba(var(--tone-rgb), 0.28);
  }
  .p-bar {
    position: absolute;
    left: 0;
    top: 20px;
    bottom: 20px;
    width: 2px;
    border-radius: 2px;
    background: var(--tone);
    box-shadow: 0 0 9px rgba(var(--tone-rgb), 0.45);
    opacity: 0.75;
  }
  .p-status {
    display: flex;
    align-items: center;
    gap: 9px;
  }
  .p-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--tone);
    box-shadow: 0 0 8px rgba(var(--tone-rgb), 0.7);
  }
  .paper.tone-blue .p-dot {
    animation: ej-pulse 2.8s ease-in-out infinite;
  }
  .p-status-label {
    color: #9a9aa2;
    font-family: var(--ej-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .p-venue {
    margin-left: auto;
    color: var(--ej-mut);
    font-family: var(--ej-mono);
    font-size: 11px;
    font-weight: 500;
  }
  h3 {
    margin: 12px 0 0;
    color: var(--ej-text);
    font-family: var(--ej-serif);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1.3;
  }
  .p-dek {
    margin: 8px 0 0;
    color: var(--ej-text-3);
    font-family: var(--ej-serif);
    font-size: 15px;
    font-style: italic;
    font-weight: 300;
    line-height: 1.5;
  }
  .p-abstract {
    margin: 12px 0 0;
    max-width: 68ch;
    color: #b8b8c0;
    font-size: 14px;
    line-height: 1.7;
    text-wrap: pretty;
  }
  .p-foot {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
  .p-contrib {
    color: var(--ej-mut);
    font-family: var(--ej-mono);
    font-size: 10.5px;
    line-height: 1.6;
  }
  .p-links {
    display: flex;
    gap: 14px;
    flex-shrink: 0;
  }
  .p-links a {
    color: #9a9aa2;
    font-family: var(--ej-mono);
    font-size: 11px;
    font-weight: 500;
    text-decoration: none;
    transition: all 120ms var(--ej-ease);
  }
  .p-links a:hover {
    color: var(--ej-blue-2);
    text-shadow: 0 0 12px rgba(76, 194, 255, 0.5);
  }

  .method {
    padding: clamp(48px, 7vh, 68px) 0 0;
  }
  .m-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(250px, 1fr);
    gap: 14px;
  }
  .m-card {
    padding: 20px 24px;
    border: 1px solid rgba(255, 255, 255, 0.075);
    border-radius: 12px;
    background: linear-gradient(180deg, #0d0d10, #0a0a0c);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.7),
      0 16px 40px -20px rgba(0, 0, 0, 0.9),
      inset 0 1px 0 rgba(255, 255, 255, 0.055);
  }
  .m-label {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--ej-mut);
    font-family: var(--ej-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .m-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--ej-amber);
    box-shadow: 0 0 8px rgba(245, 158, 11, 0.7);
  }
  .m-rows {
    display: grid;
    gap: 2px;
    margin-top: 12px;
  }
  .m-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 7px 2px;
  }
  .m-key {
    flex-shrink: 0;
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: color 120ms ease;
  }
  .m-lead {
    flex: 1;
    min-width: 14px;
    border-bottom: 1px dotted rgba(255, 255, 255, 0.11);
    transform: translateY(-3px);
    transition: border-color 120ms ease;
  }
  .m-val {
    flex-shrink: 0;
    max-width: 60%;
    text-align: right;
    color: #e8e8ea;
    font-family: var(--ej-mono);
    font-size: 12px;
    line-height: 1.6;
    transition: color 120ms ease;
  }
  .m-row:hover .m-key { color: var(--ej-text-2); }
  .m-row:hover .m-lead { border-bottom-color: rgba(255, 255, 255, 0.22); }
  .m-row:hover .m-val { color: #fff; }
  .m-metric {
    display: grid;
    align-content: center;
    gap: 8px;
  }
  .m-value {
    color: var(--ej-text);
    font-family: var(--ej-mono);
    font-size: 27px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .m-note {
    color: #9a9aa2;
    font-family: var(--ej-mono);
    font-size: 11.5px;
    line-height: 1.6;
  }
  .m-honesty {
    margin: 6px 0 0;
    color: var(--ej-mut);
    font-size: 12.5px;
    line-height: 1.65;
    text-wrap: pretty;
  }

  .tl {
    padding: clamp(48px, 7vh, 68px) 0 0;
  }
  .cv {
    color: #9a9aa2;
    font-family: var(--ej-mono);
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    transition: all 120ms var(--ej-ease);
  }
  .cv:hover {
    color: var(--ej-amber-2);
    border-bottom-color: rgba(245, 158, 11, 0.55);
    text-shadow: 0 0 12px rgba(245, 158, 11, 0.4);
  }
  .tl-list {
    position: relative;
    padding: 4px 0;
  }
  .tl-row {
    --tone: var(--ej-pink);
    --tone-rgb: 255, 122, 192;
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 18px;
    padding: 10px 0 10px 2px;
  }
  .tl-row.tone-blue { --tone: var(--ej-blue); --tone-rgb: 76, 194, 255; }
  .tl-row.tone-amber { --tone: var(--ej-amber); --tone-rgb: 245, 158, 11; }
  .tl-row.tone-gray { --tone: #8a8a94; --tone-rgb: 138, 138, 148; }
  .tl-when {
    flex-shrink: 0;
    width: 52px;
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: 11.5px;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }
  .tl-node {
    flex-shrink: 0;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--tone);
    box-shadow: 0 0 8px rgba(var(--tone-rgb), 0.6);
    transform: translateY(-1px);
  }
  .tl-row.tone-gray .tl-node {
    box-shadow: none;
  }
  .tl-label {
    color: var(--ej-text-2);
    font-size: 14px;
    line-height: 1.6;
  }

  .next {
    padding: clamp(48px, 7vh, 68px) 0 clamp(56px, 8vh, 72px);
  }
  .next-card {
    display: grid;
    gap: 10px;
    padding: 20px 24px;
    border: 1px solid rgba(255, 255, 255, 0.075);
    border-radius: 12px;
    background: linear-gradient(180deg, #0d0d10, #0a0a0c);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.7),
      0 16px 40px -20px rgba(0, 0, 0, 0.9),
      inset 0 1px 0 rgba(255, 255, 255, 0.055);
  }
  .next-label {
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.2em;
  }
  .next-text {
    margin: 0;
    max-width: 62ch;
    color: var(--ej-text-2);
    font-size: 14.5px;
    line-height: 1.7;
    text-wrap: pretty;
  }
  .next-link {
    justify-self: start;
    color: #9a9aa2;
    font-family: var(--ej-mono);
    font-size: 11.5px;
    font-weight: 500;
    text-decoration: none;
    transition: all 120ms var(--ej-ease);
  }
  .next-link:hover {
    color: var(--ej-pink-2);
    text-shadow: 0 0 12px rgba(255, 122, 192, 0.5);
  }

  @media (max-width: 980px) {
    .m-grid {
      grid-template-columns: 1fr;
    }
    .p-foot {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
