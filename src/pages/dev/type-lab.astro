---
// Lexend 定夺页(noindex, 定了就删 + 卸 lexend 包): 真实文章「Who Am I」全文用 Lexend 排,
// 顶部可实时切 300/350/400 三档字重 — 因为印觉得 Lexend 400 "有点在读/over". 对照组是真身:
// /posts/who-am-i/(现役 Noto Sans 400). 结论只有两种: "换 Lexend + 定档" 或 "维持 Noto Sans".
import '@fontsource-variable/lexend/index.css';
import '../../styles/prose.css';
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';

const post = await getEntry('posts', 'who-am-i');
if (!post) throw new Error('type-lab: post who-am-i not found');
const { Content } = await render(post);
---

<BaseLayout title="Type lab — Lexend 定夺" description="Lexend body, real article, live weight." noindex>
  <main style="--ej-page-w: 720px;">
    <section class="reveal" style="--reveal-i: 0;">
      <p class="ej-kicker">TYPE LAB — LEXEND AS BODY · REAL ARTICLE</p>
      <h1 class="ej-h1 ej-h1--sm">「Who Am I」in Lexend.<span class="ej-caret" aria-hidden="true"></span></h1>
      <p class="ej-sub">
        全文用 Lexend 排. 上面三个钮实时切字重 —
        400 是你嫌"在读"的那档, 试试 350/300 是否松一口气. 对照真身(现役 Noto Sans 400):
        <a class="ej-link ej-link--blue" href="/posts/who-am-i/" data-route="→ /posts/who-am-i/ — Noto Sans 真身" style="margin-left:6px;">原文 →</a>
      </p>
      <div class="wsw" id="wsw">
        <span class="wsw-label">LEXEND WEIGHT</span>
        <button type="button" data-w="300">300 light</button>
        <button type="button" data-w="350" class="on">350</button>
        <button type="button" data-w="400">400 现档</button>
      </div>
    </section>

    <section class="reveal" style="--reveal-i: 1;">
      <article class="prose lex" id="lex">
        <Content />
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  /* 只在这页把 sans 换 Lexend + 用变量托字重; 标题仍 Source Serif(只测正文体). */
  .lex {
    --ej-sans: 'Lexend Variable', system-ui, sans-serif;
    --lex-weight: 350;
  }
  .lex :global(p),
  .lex :global(li) {
    font-weight: var(--lex-weight);
    letter-spacing: -0.006em; /* Lexend 偏宽, 收一丝减少"松散" */
  }

  .wsw {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 22px;
  }
  .wsw-label {
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-micro);
    font-weight: 500;
    letter-spacing: 0.18em;
    margin-right: 4px;
  }
  .wsw button {
    padding: 4px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: transparent;
    color: #9a9aa2;
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-small);
    cursor: pointer;
    transition: all 130ms var(--ej-ease);
  }
  .wsw button:hover {
    border-color: rgba(255, 255, 255, 0.26);
    color: #e8e8ea;
  }
  .wsw button.on {
    border-color: rgba(255, 122, 192, 0.45);
    background: rgba(255, 122, 192, 0.08);
    color: var(--ej-pink-2);
  }
</style>

<script is:inline>
  (() => {
    const lex = document.getElementById('lex');
    const sw = document.getElementById('wsw');
    if (!lex || !sw) return;
    sw.addEventListener('click', (e) => {
      const b = e.target.closest('button[data-w]');
      if (!b) return;
      lex.style.setProperty('--lex-weight', b.dataset.w);
      sw.querySelectorAll('button').forEach((x) => x.classList.toggle('on', x === b));
    });
  })();
</script>
