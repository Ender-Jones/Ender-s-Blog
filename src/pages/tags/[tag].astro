---
// Tag 页: 某个 tag 下的全部文章, 复用签名行样式的精简版.
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import RouteHint from '../../components/home/RouteHint.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((p) => p.data.language === 'en');
  const slug = (tag: string) =>
    tag.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  const byTag = new Map<string, { label: string; posts: typeof posts }>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      const s = slug(tag);
      const bucket = byTag.get(s) ?? { label: tag.toLowerCase(), posts: [] };
      bucket.posts.push(post);
      byTag.set(s, bucket);
    }
  }
  return [...byTag.entries()].map(([tag, { label, posts: tagged }]) => ({
    params: { tag },
    props: { label, posts: tagged },
  }));
}

const { label, posts } = Astro.props;
const sorted = [...posts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' });
const toneOf = (kind: string) => (kind === 'poem' || kind === 'essay' ? 'pink' : 'blue');
const kindLabel = (kind: string) =>
  kind === 'research-note' ? 'note' : kind === 'field-report' ? 'field' : kind;
const href = (id: string) => `/posts/${id.replace(/\.(md|mdx)$/, '')}/`;
---

<BaseLayout title={`#${label} — Ender Jones`} description={`Posts filed under #${label}.`} noindex>
  <RouteHint />
  <main style="--ej-page-w: 980px;">
    <section class="reveal" style="--reveal-i: 0;">
      <p class="ej-kicker">FILED UNDER</p>
      <h1 class="ej-h1 ej-h1--sm">#{label}<span class="ej-caret" aria-hidden="true"></span></h1>
      <p class="ej-sub">{sorted.length} post{sorted.length === 1 ? '' : 's'} · <a class="ej-link" href="/posts/" data-route="→ /posts/ — the archive">all writing →</a></p>
    </section>

    <section class="list reveal" style="--reveal-i: 1;">
      {sorted.map((p) => (
        <a class:list={['row', `tone-${toneOf(p.data.kind)}`]} href={href(p.id)} data-route={`→ ${href(p.id)}`}>
          <span class="bar" aria-hidden="true"></span>
          <span class="date">{fmtDate(p.data.date)}</span>
          <span class="mid">
            <strong class="title">{p.data.title}</strong>
            {p.data.description && <span class="desc">{p.data.description}</span>}
          </span>
          <span class="meta">{kindLabel(p.data.kind)}</span>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>

<style>

  .list {
    padding: clamp(24px, 4vh, 36px) 0 clamp(56px, 8vh, 72px);
  }
  .row {
    position: relative;
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr) 90px;
    gap: 20px;
    align-items: baseline;
    padding: 17px 12px 17px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.055);
    text-decoration: none;
    transition: background 180ms var(--ej-ease);
  }
  .row:hover {
    background: rgba(255, 255, 255, 0.014);
  }
  .bar {
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 2px;
    border-radius: 2px;
    background: var(--tone);
    box-shadow: 0 0 9px rgba(var(--tone-rgb), 0.55);
    opacity: 0;
    transform: scaleY(0.55);
    transition:
      opacity 180ms var(--ej-ease),
      transform 220ms var(--ej-ease);
  }
  .row:hover .bar {
    opacity: 1;
    transform: scaleY(1);
  }
  .date {
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-label);
    font-weight: var(--ej-fw-medium);
    font-variant-numeric: tabular-nums;
    transition: color 180ms ease;
  }
  .row:hover .date {
    color: #e9e9ec;
  }
  .mid {
    min-width: 0;
    display: grid;
    gap: 5px;
  }
  .title {
    color: var(--ej-text-2);
    font-family: var(--ej-serif);
    font-size: 19px;
    font-weight: var(--ej-fw-medium);
    line-height: var(--ej-lh-snug);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition:
      color 180ms ease,
      transform 220ms var(--ej-ease);
  }
  .row:hover .title {
    color: #fff;
    transform: translateX(4px);
  }
  .desc {
    color: #8f8f96;
    font-size: var(--ej-fs-note);
    line-height: 1.55;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .meta {
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-label);
    font-weight: var(--ej-fw-medium);
    text-align: right;
  }
  @media (max-width: 720px) {
    .row {
      grid-template-columns: 90px minmax(0, 1fr);
    }
    .meta {
      display: none;
    }
    .title,
    .desc {
      white-space: normal;
    }
  }
</style>
