---
// 录入台(本地模式): 捕获 ≤10s · 三出口 carry-over · 日终仪式 · 生成当日 markdown 块.
// 逻辑日以 04:00 JST 为界(凌晨的活算前一天). 真 push 在 go-live 时由 D1 + Pages Function 接管;
// 本地模式的 "copy the day" 把整块 markdown 复制到剪贴板, 粘进月度文件再 git push 即可.
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import RouteHint from '../../components/home/RouteHint.astro';
import { getWorklogDays } from '../../lib/worklogDays';

const worklogs = await getCollection('worklogs');
const days = getWorklogDays(worklogs);

// carry-over 候选: 最近几个带 > next 的日子(逻辑日在客户端才知道, 由客户端挑"今天之前"的最新一天)
const latestDay = days[0];
const consoleData = {
  nextDays: days
    .filter((d) => d.items.some((i) => i.type === 'next'))
    .slice(0, 5)
    .map((d) => ({ date: d.date, texts: d.items.filter((i) => i.type === 'next').map((i) => i.text) })),
  lastNote: latestDay?.date ?? '',
  noteDays: days.map((d) => d.date),
};
---

<BaseLayout title="Entry console — Ender Jones" description="Worklog entry console." noindex>
  <RouteHint />
  <main>
    <header class="head reveal" style="--reveal-i: 0;">
      <div>
        <p class="kicker">WORKLOG — ENTRY CONSOLE · APPEND-ONLY</p>
        <h1>Log today<span class="caret" aria-hidden="true"></span></h1>
        <p class="sub">One line is enough. Your future self is the reader.</p>
      </div>
      <div class="who">
        <span class="avatar" aria-hidden="true"></span>
        <span class="who-col">
          <span class="who-name">@Ender-Jones</span>
          <span class="who-mode"><span class="mode-dot" aria-hidden="true"></span>LOCAL MODE · real push lands at go-live</span>
        </span>
      </div>
    </header>

    <section class="grid reveal" style="--reveal-i: 1;">
      <div class="col-l">
        <div class="card capture">
          <div class="date-strip">
            <span class="ds-left">
              <span class="ds-date" id="c-date">----------</span>
              <span class="ds-wd" id="c-wd"></span>
              <span class="ds-night" id="c-night" hidden>night session — counts until 04:00</span>
            </span>
            <span class="ds-right">
              <span class="ds-last" id="c-last"></span>
              <span class="ds-clock"><span id="c-clock">--:--:--</span> JST <span class="blink" aria-hidden="true">▍</span></span>
            </span>
          </div>

          <div class="input-row">
            <span class="prompt" aria-hidden="true">▸</span>
            <input id="c-input" type="text" placeholder="type what happened… Enter to log" autocomplete="off" />
            <span class="type-preview" id="c-preview"></span>
          </div>

          <div class="chips" id="c-chips">
            <button type="button" class="chip-project" data-tok="@" data-route="insert prefix — project"><span class="tok">@</span> project</button>
            <button type="button" class="chip-decision" data-tok="=" data-route="insert prefix — decision"><span class="tok">=</span> decision</button>
            <button type="button" class="chip-risk" data-tok="!" data-route="insert prefix — risk"><span class="tok">!</span> risk</button>
            <button type="button" class="chip-next" data-tok=">" data-route="insert prefix — next"><span class="tok">&gt;</span> next</button>
          </div>

          <div class="entries" id="c-entries">
            <p class="empty" id="c-empty">nothing logged yet today — one line is enough.</p>
          </div>
        </div>

        <div class="card carry" id="c-carry-card" hidden>
          <div class="carry-head">
            <span class="carry-label">CARRY-OVER — NEXT FROM <span id="c-carry-from"></span></span>
            <span class="carry-hint">zero-thought resume</span>
          </div>
          <div id="c-carry"></div>
        </div>

        <div class="syntax">
          <div class="syn-row">
            <span class="syn-label">PREFIXES</span>
            <span><span class="s-project">@</span> project</span>
            <span><span class="s-decision">=</span> decision</span>
            <span><span class="s-risk">!</span> risk</span>
            <span><span class="s-next">&gt;</span> next</span>
            <span class="syn-dim">no prefix = done</span>
          </div>
          <div class="syn-row">
            <span class="syn-label">CARRY-OVER EXITS</span>
            <span><span class="s-done">✓</span> done</span>
            <span><span class="s-next">→</span> still next</span>
            <span><span class="s-dropped">×</span> drop <span class="syn-dim">(a decision, not a failure)</span></span>
          </div>
        </div>
      </div>

      <div class="col-r">
        <div class="card file">
          <div class="goes">
            <span class="goes-label">WHERE THIS GOES</span>
            <span class="goes-text">
              <span class="goes-line">every line appends to <span class="goes-path" id="c-path2">content/worklogs/….md</span></span>
              <span class="goes-line"><span id="c-go-close">close the day</span> hands you the commit</span>
              <span class="goes-line">your one public sentence becomes the homepage <span id="c-go-now">NOW</span></span>
            </span>
          </div>
          <div class="file-head">
            <span class="file-path" id="c-path">content/worklogs/….md</span>
            <span class="file-meta"><span>local · draft</span><span class="diff" id="c-diff">+0 −0</span></span>
          </div>
          <div class="md" id="c-md"></div>
          <div class="commit">
            <div class="ritual" id="c-ritual" hidden>
              <div class="rit-head">
                <span class="rit-label">DAY CLOSE — UNDER A MINUTE</span>
                <button type="button" id="c-rit-x" data-route="not yet — keep logging">× not yet</button>
              </div>
              <p class="rit-recap" id="c-recap"></p>
              <div class="rit-next" id="c-rit-next-wrap">
                <span class="rit-sub">SAVE POINT — FIRST THING TOMORROW</span>
                <input id="c-rit-next" type="text" placeholder="one line — logged as > next" autocomplete="off" />
              </div>
              <p class="rit-havenext" id="c-rit-havenext" hidden><span>save point ✓</span> — <span id="c-rit-nextprev"></span></p>
              <div class="rit-public">
                <div class="rit-public-head">
                  <span class="rit-sub rit-sub-pink"><span class="pink-dot" aria-hidden="true"></span>PUBLIC LINE — HOMEPAGE “NOW”</span>
                  <span class="rit-count" id="c-count">0/140</span>
                </div>
                <input id="c-summary" type="text" maxlength="140" placeholder="one sentence for everyone else…" autocomplete="off" />
              </div>
              <div class="rit-energy">
                <span class="rit-sub">ENERGY</span>
                <span class="e-dots" id="c-energy">
                  <button type="button" data-n="1">1</button>
                  <button type="button" data-n="2">2</button>
                  <button type="button" data-n="3">3</button>
                  <button type="button" data-n="4">4</button>
                  <button type="button" data-n="5">5</button>
                </span>
                <span class="rit-opt">optional — patterns, not grades</span>
              </div>
            </div>
            <div class="commit-bar">
              <span class="commit-msg" id="c-msg">nothing to commit</span>
              <button type="button" id="c-commit" disabled>nothing to commit</button>
            </div>
            <div id="c-commit-lines"></div>
          </div>
        </div>

        <div class="card trail-card">
          <div class="trail-head">
            <span class="trail-label">LOG TRAIL — 26 WEEKS</span>
            <a href="/worklog/" data-route="→ /worklog/ — the full log">worklog →</a>
          </div>
          <div class="trail" id="c-trail"></div>
          <p class="trail-note" id="c-trailnote">pink — a day with a note · amber — today · gaps are neutral, nothing counts against you.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline type="application/json" id="c-data" set:html={JSON.stringify(consoleData)} />

<script>
  type EntryType = 'project' | 'done' | 'decision' | 'risk' | 'next' | 'dropped';
  type Entry = { type: EntryType; text: string; time: string };

  const RAW = JSON.parse(document.getElementById('c-data')!.textContent || '{}') as {
    nextDays: { date: string; texts: string[] }[];
    lastNote: string;
    noteDays: string[];
  };

  const $ = <T extends HTMLElement = HTMLElement>(id: string) =>
    document.getElementById(id) as T;

  const TYPE_META: Record<EntryType, { label: string; cls: string; color: string; border: string; bg: string }> = {
    project: { label: 'PROJECT', cls: 't-project', color: '#c8c8cd', border: 'rgba(255,255,255,0.22)', bg: 'transparent' },
    done: { label: 'DONE', cls: 't-done', color: '#e8e8ea', border: 'transparent', bg: 'rgba(255,255,255,0.08)' },
    decision: { label: 'DECISION', cls: 't-decision', color: '#9ed9ff', border: 'rgba(76,194,255,0.38)', bg: 'transparent' },
    risk: { label: 'RISK', cls: 't-risk', color: '#ff9d9d', border: 'rgba(255,120,120,0.4)', bg: 'transparent' },
    next: { label: 'NEXT', cls: 't-next', color: '#fcd34d', border: 'transparent', bg: 'rgba(245,158,11,0.14)' },
    dropped: { label: 'DROPPED', cls: 't-dropped', color: '#8a8a94', border: 'rgba(255,255,255,0.16)', bg: 'transparent' },
  };
  const SECTION: Record<EntryType, string> = {
    project: 'Project',
    done: 'Done',
    decision: 'Decision',
    risk: 'Risk',
    next: 'Next',
    dropped: 'Dropped',
  };

  // ---- 逻辑日: JST − 4h(凌晨算前一天) ----
  const jstNow = () => new Date(Date.now() + 9 * 3600_000);
  const iso = (d: Date) => d.toISOString().slice(0, 10);
  const logicalDate = () => iso(new Date(jstNow().getTime() - 4 * 3600_000));
  const isNightSession = () => iso(jstNow()) !== logicalDate();
  const jstClock = () => jstNow().toISOString().slice(11, 19);
  const jstHM = () => jstNow().toISOString().slice(11, 16);

  const today = logicalDate();
  const month = today.slice(0, 7);
  const filePath = `content/worklogs/${month}.md`;
  const LS_KEY = `ej-console-${today}`;

  // carry-over = 逻辑日"今天之前"最近一天的 next
  const carrySource = RAW.nextDays.find((d) => d.date < today);
  const DATA = {
    carry: carrySource?.texts ?? [],
    carryFrom: carrySource?.date ?? '',
    lastNote: RAW.lastNote,
    noteDays: RAW.noteDays,
  };

  // ---- 状态 ----
  type State = {
    entries: Entry[];
    usedCarry: number[];
    droppedCarry: number[];
    committed: boolean;
    summary: string;
    energy: number;
  };
  const state: State = {
    entries: [],
    usedCarry: [],
    droppedCarry: [],
    committed: false,
    summary: '',
    energy: 0,
  };
  let ritualOpen = false;
  let ritualNext = '';

  try {
    const saved = JSON.parse(localStorage.getItem(LS_KEY) || 'null');
    if (saved && Array.isArray(saved.entries)) Object.assign(state, saved);
  } catch {}

  const save = () => {
    try {
      localStorage.setItem(LS_KEY, JSON.stringify(state));
    } catch {}
  };

  const parse = (t: string): { type: EntryType; text: string } => {
    const map: Record<string, EntryType> = {
      '@': 'project',
      '=': 'decision',
      '!': 'risk',
      '>': 'next',
      '~': 'dropped',
    };
    const c = t.charAt(0);
    if (map[c]) return { type: map[c], text: t.slice(1).trim() };
    return { type: 'done', text: t };
  };

  // ---- markdown 生成(和站点解析器同一格式) ----
  const mdLines = (): string[] => {
    const lines = [`## ${today}`];
    if (state.energy) lines.push(`<!-- energy: ${state.energy} -->`);
    for (const type of ['project', 'done', 'decision', 'risk', 'next', 'dropped'] as EntryType[]) {
      const items = state.entries.filter((e) => e.type === type);
      if (!items.length) continue;
      lines.push('', `### ${SECTION[type]}`);
      for (const item of items)
        lines.push(type === 'dropped' ? `- ~~${item.text}~~` : `- ${item.text}`);
    }
    if (state.summary.trim()) lines.push('', '### Public', `- ${state.summary.trim()}`);
    return lines;
  };

  // ---- 渲染 ----
  const input = $<HTMLInputElement>('c-input');
  const preview = $('c-preview');
  const chipEls = [...document.querySelectorAll<HTMLButtonElement>('#c-chips button')];

  const renderPreviewChip = () => {
    const t = input.value.trim();
    const first = t.charAt(0);
    for (const chip of chipEls) chip.classList.toggle('active', chip.dataset.tok === first);
    if (!t) {
      preview.className = 'type-preview';
      preview.textContent = '';
      preview.style.cssText = '';
      return;
    }
    const p = parse(t);
    const meta = TYPE_META[p.type];
    preview.className = 'type-preview on';
    preview.textContent = `→ ${meta.label}`;
    preview.style.color = meta.color;
    preview.style.borderColor = meta.border;
    preview.style.background = meta.bg;
  };

  const renderEntries = () => {
    const box = $('c-entries');
    box.querySelectorAll('.entry-row').forEach((n) => n.remove());
    $('c-empty').hidden = state.entries.length > 0;
    state.entries.forEach((entry, i) => {
      const row = document.createElement('div');
      row.className = 'entry-row';
      const badge = document.createElement('span');
      badge.className = `badge ${TYPE_META[entry.type].cls}`;
      badge.textContent = TYPE_META[entry.type].label;
      const text = document.createElement('span');
      text.className = 'entry-text';
      text.textContent = entry.text;
      const time = document.createElement('span');
      time.className = 'entry-time';
      time.textContent = entry.time;
      const del = document.createElement('button');
      del.className = 'entry-del';
      del.type = 'button';
      del.textContent = '×';
      del.addEventListener('click', () => {
        state.entries.splice(i, 1);
        state.committed = false;
        save();
        renderAll();
      });
      row.append(badge, text, time, del);
      box.append(row);
    });
  };

  const renderCarry = () => {
    const card = $('c-carry-card');
    if (!DATA.carry.length) {
      card.hidden = true;
      return;
    }
    card.hidden = false;
    $('c-carry-from').textContent = DATA.carryFrom;
    const box = $('c-carry');
    box.textContent = '';
    DATA.carry.forEach((text, i) => {
      const used = state.usedCarry.includes(i);
      const dropped = state.droppedCarry.includes(i);
      const row = document.createElement('div');
      row.className = 'carry-row' + (used || dropped ? ' spent' : '');
      const t = document.createElement('span');
      t.className = 'carry-text' + (used || dropped ? ' strike' : '');
      t.textContent = text;
      row.append(t);
      if (used || dropped) {
        const label = document.createElement('span');
        label.className = 'carry-spent';
        label.textContent = dropped ? 'DROPPED —' : 'LOGGED ✓';
        row.append(label);
      } else {
        const actions = document.createElement('span');
        actions.className = 'carry-actions';
        const mk = (label: string, cls: string, fn: () => void) => {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = cls;
          b.textContent = label;
          b.addEventListener('click', fn);
          return b;
        };
        actions.append(
          mk('✓ done', 'ca ca-done', () => useCarry(i, 'done')),
          mk('→ still next', 'ca ca-amber', () => useCarry(i, 'next')),
          mk('× drop', 'ca ca-drop', () => useCarry(i, 'dropped')),
        );
        row.append(actions);
      }
      box.append(row);
    });
  };

  const useCarry = (i: number, type: EntryType) => {
    if (type === 'dropped') state.droppedCarry.push(i);
    else state.usedCarry.push(i);
    addEntry(type, DATA.carry[i]);
  };

  // 昨天的 next 不给出口(done / still next / drop)就不准关今天 — 迁移即对抗
  const pendingCarry = () =>
    DATA.carry.filter((_, i) => !state.usedCarry.includes(i) && !state.droppedCarry.includes(i))
      .length;

  const renderMd = () => {
    const box = $('c-md');
    box.textContent = '';
    const lines = mdLines();
    for (const line of lines) {
      const div = document.createElement('div');
      div.textContent = line || ' ';
      if (line.startsWith('## ')) div.className = 'md-h2';
      else if (line.startsWith('### ')) div.className = 'md-h3';
      else if (line.startsWith('<!--')) div.className = 'md-dim';
      else if (line.startsWith('- ~~')) div.className = 'md-dropped';
      else div.className = 'md-line';
      box.append(div);
    }
    $('c-diff').textContent = `+${lines.length} −0`;
  };

  const renderGoes = () => {
    $('c-go-close').className = state.entries.length ? 'go-on-amber' : 'go-off';
    $('c-go-now').className = state.committed ? 'go-on-pink' : 'go-off';
  };

  const renderCommit = () => {
    const btn = $<HTMLButtonElement>('c-commit');
    const msg = $('c-msg');
    const n = state.entries.length;
    const pending = pendingCarry();
    msg.textContent = n ? `worklog: ${today} (${n} ${n === 1 ? 'entry' : 'entries'})` : 'nothing to commit';
    const canClose = n > 0 && !state.committed && pending === 0;
    btn.disabled = !canClose;
    btn.className = state.committed ? 'done' : ritualOpen ? 'push' : '';
    btn.textContent = state.committed
      ? '✓ copied — paste & push'
      : ritualOpen
        ? 'copy the day →'
        : n && pending
          ? `triage carry-over first (${pending})`
          : n
            ? 'close the day'
            : 'nothing to commit';
    btn.dataset.route = state.committed
      ? `pasted into ${filePath}? then: git push`
      : ritualOpen
        ? 'local mode — copies the markdown block'
        : n && pending
          ? "yesterday's next needs an exit — done / still next / drop"
          : n
            ? 'day close — recap · save point · public line · energy'
            : 'log something first';
  };

  const renderRitual = () => {
    $('c-ritual').hidden = !ritualOpen || state.committed;
    if (!ritualOpen) return;
    const counts: Partial<Record<EntryType, number>> = {};
    for (const e of state.entries) counts[e.type] = (counts[e.type] ?? 0) + 1;
    const parts: string[] = [];
    if (counts.done) parts.push(`${counts.done} done`);
    if (counts.decision) parts.push(`${counts.decision} decision${counts.decision === 1 ? '' : 's'}`);
    if (counts.risk) parts.push(`${counts.risk} risk${counts.risk === 1 ? '' : 's'}`);
    if (counts.dropped) parts.push(`${counts.dropped} dropped`);
    if (counts.next) parts.push(`${counts.next} next`);
    $('c-recap').textContent =
      (parts.length ? parts.join(' · ') : `${state.entries.length} notes`) + ' — proof, not memory.';
    const nexts = state.entries.filter((e) => e.type === 'next');
    $('c-rit-next-wrap').hidden = nexts.length > 0;
    $('c-rit-havenext').hidden = nexts.length === 0;
    if (nexts.length) $('c-rit-nextprev').textContent = `“${nexts[nexts.length - 1].text}”`;
    $('c-count').textContent = `${state.summary.length}/140`;
    $('c-energy')
      .querySelectorAll('button')
      .forEach((b) => b.classList.toggle('on', Number(b.dataset.n) <= state.energy));
  };

  const renderTrail = () => {
    const box = $('c-trail');
    box.textContent = '';
    const noteSet = new Set(DATA.noteDays);
    if (state.committed) noteSet.add(today);
    const base = new Date(`${today}T12:00:00Z`);
    for (let i = 181; i >= 0; i--) {
      const d = iso(new Date(base.getTime() - i * 86400_000));
      const cell = document.createElement('span');
      const note = noteSet.has(d);
      cell.className = 'cell' + (note ? ' note' : '') + (i === 0 ? ' today' : '');
      cell.title = i === 0 ? `today${note ? ' · note ready' : ' — nothing yet, no penalty'}` : d + (note ? ' · note' : '');
      box.append(cell);
    }
    $('c-trailnote').textContent = state.committed
      ? 'copied — today turns pink inside its amber frame once pushed.\ngaps stay neutral: no streaks, no guilt.'
      : 'pink — a day with a note · amber — today\ngaps are neutral, nothing counts against you.';
  };

  const renderAll = () => {
    renderEntries();
    renderCarry();
    renderMd();
    renderGoes();
    renderCommit();
    renderRitual();
    renderTrail();
    renderPreviewChip();
  };

  const addEntry = (type: EntryType, text: string) => {
    if (!text.trim()) return;
    state.entries.push({ type, text: text.trim(), time: jstHM() });
    state.committed = false;
    save();
    renderAll();
  };

  // ---- 事件 ----
  input.addEventListener('input', renderPreviewChip);
  input.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    const p = parse(input.value.trim());
    if (!p.text) return;
    input.value = '';
    addEntry(p.type, p.text);
  });

  $('c-chips')
    .querySelectorAll<HTMLButtonElement>('button')
    .forEach((chip) => {
      chip.addEventListener('click', () => {
        input.value = `${chip.dataset.tok} ${input.value.replace(/^[@=!>~]\s*/, '')}`;
        input.focus();
        renderPreviewChip();
      });
    });

  $('c-commit').addEventListener('click', async () => {
    if (state.committed || !state.entries.length || pendingCarry() > 0) return;
    if (!ritualOpen) {
      ritualOpen = true;
      renderCommit();
      renderRitual();
      $<HTMLInputElement>('c-summary').value = state.summary;
      return;
    }
    // copy the day (本地模式的 push)
    const nextVal = ritualNext.trim();
    if (nextVal && !state.entries.some((e) => e.type === 'next')) {
      state.entries.push({ type: 'next', text: nextVal, time: jstHM() });
      ritualNext = '';
    }
    const block = mdLines().join('\n') + '\n';
    let copied = false;
    try {
      await navigator.clipboard.writeText(block);
      copied = true;
    } catch {}
    state.committed = true;
    ritualOpen = false;
    save();
    renderAll();
    const lines = $('c-commit-lines');
    lines.textContent = '';
    const note = document.createElement('p');
    note.className = 'commit-line';
    note.innerHTML = `<span>✓</span> ${copied ? 'copied to clipboard' : 'select the preview above to copy'} — paste into <b>${filePath}</b>, then <b>git push</b>`;
    lines.append(note);
  });

  $('c-rit-x').addEventListener('click', () => {
    ritualOpen = false;
    renderCommit();
    renderRitual();
  });
  $<HTMLInputElement>('c-rit-next').addEventListener('input', (e) => {
    ritualNext = (e.target as HTMLInputElement).value;
  });
  $<HTMLInputElement>('c-summary').addEventListener('input', (e) => {
    state.summary = (e.target as HTMLInputElement).value.slice(0, 140);
    state.committed = false;
    save();
    $('c-count').textContent = `${state.summary.length}/140`;
    renderMd();
    renderCommit();
  });
  $('c-energy')
    .querySelectorAll<HTMLButtonElement>('button')
    .forEach((b) => {
      b.addEventListener('click', () => {
        const n = Number(b.dataset.n);
        state.energy = state.energy === n ? 0 : n;
        save();
        renderRitual();
        renderMd();
      });
    });

  // ---- 时钟与日期条 ----
  $('c-date').textContent = today;
  $('c-wd').textContent = new Date(`${today}T12:00:00Z`)
    .toLocaleDateString('en-US', { weekday: 'short', timeZone: 'UTC' })
    .toUpperCase();
  $('c-night').hidden = !isNightSession();
  if (DATA.lastNote) {
    const ago = Math.max(
      0,
      Math.round((new Date(`${today}T12:00:00Z`).getTime() - new Date(`${DATA.lastNote}T12:00:00Z`).getTime()) / 86400_000),
    );
    $('c-last').textContent = `last note ${DATA.lastNote} · ${ago}d ago`;
  }
  $('c-path').textContent = filePath;
  $('c-path2').textContent = filePath;
  const tick = () => {
    $('c-clock').textContent = jstClock();
  };
  tick();
  setInterval(tick, 1000);

  renderAll();
</script>

