---
// 录入台(LIVE): 捕获 ≤10s · 三出口 carry-over · 日终仪式 · /api 直写 D1 当日工作区.
// 逻辑日以 04:00 JST 为界(凌晨的活算前一天). 每行 POST /api/log 即存; close-the-day 由
// Pages Function 编 markdown 提交进 git(server 持 PAT). 失败不缓冲: 报错 + 重试(已定论).
// 首次载入会把旧 local-mode 的 localStorage 草稿一次性迁移进 D1.
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import RouteHint from '../../components/home/RouteHint.astro';
import activity from '../../data/github-activity.json';
import { getWorklogDays } from '../../lib/worklogDays';

const worklogs = await getCollection('worklogs');
const days = getWorklogDays(worklogs);

// carry-over 候选: 最近几个带 > next 的日子(逻辑日在客户端才知道, 由客户端挑"今天之前"的最新一天)
const latestDay = days[0];
// md 预览卡的灰色回看区: 最近两个月文件的原文(构建期快照, 补关上月日子时也有得看)
const monthBodies = Object.fromEntries(
  [...worklogs]
    .map((w) => [w.id.slice(0, 7), w.body ?? ''] as const)
    .sort((a, b) => (a[0] < b[0] ? 1 : -1))
    .slice(0, 2),
);
const consoleData = {
  nextDays: days
    .filter((d) => d.items.some((i) => i.type === 'next'))
    .slice(0, 5)
    .map((d) => ({ date: d.date, texts: d.items.filter((i) => i.type === 'next').map((i) => i.text) })),
  lastNote: latestDay?.date ?? '',
  activityDays: activity.days ?? [],
  monthBodies,
};
---

<BaseLayout title="Entry console — Ender Jones" description="Worklog entry console." noindex>
  <RouteHint />
  <main>
    <header class="head reveal" style="--reveal-i: 0;">
      <div>
        <p class="kicker">WORKLOG — ENTRY CONSOLE</p>
        <h1>Log today<span class="caret" aria-hidden="true"></span></h1>
      </div>
      <div class="who">
        <span class="avatar" aria-hidden="true"></span>
        <span class="who-col">
          <span class="who-name">@Ender-Jones</span>
          <span class="who-mode"><span class="mode-dot" aria-hidden="true"></span>LIVE · D1 → git at close</span>
        </span>
      </div>
    </header>

    <!-- 漏关横幅: 昨天(或更早)有未归档的行 → 一键进完整仪式补关; 多天漏关从最旧的开始 -->
    <div class="stale" id="c-stale" hidden>
      <span class="stale-text" id="c-stale-text"></span>
      <button type="button" id="c-stale-btn" data-route="close the missed day — full ritual"></button>
    </div>

    <section class="grid reveal" style="--reveal-i: 1;">
      <div class="col-l">
        <div class="ej-card card capture">
          <div class="date-strip">
            <span class="ds-left">
              <span class="ds-date" id="c-date">----------</span>
              <span class="ds-wd" id="c-wd"></span>
              <span class="ds-night" id="c-night" hidden>night session — counts until 04:00</span>
              <span class="ds-flag" id="c-flag" hidden></span>
            </span>
            <span class="ds-right">
              <span class="ds-last" id="c-last"></span>
              <span class="ds-clock"><span id="c-clock">--:--:--</span> JST <span class="blink" aria-hidden="true">▍</span></span>
            </span>
          </div>

          <div class="input-row">
            <span class="prompt" aria-hidden="true">▸</span>
            <input id="c-input" type="text" placeholder="type what happened… Enter to log" autocomplete="off" />
            <span class="type-preview" id="c-preview"></span>
          </div>

          <div class="chips" id="c-chips">
            <button type="button" class="chip-wip" data-tok="@" data-route="wip: effort — log it the moment you start; wip now + done later is a feature"><span class="tok">@</span> wip</button>
            <button type="button" class="chip-decision" data-tok="=" data-route="decision: archive only"><span class="tok">=</span> decision</button>
            <button type="button" class="chip-risk" data-tok="!" data-route="risk: archive only"><span class="tok">!</span> risk</button>
            <button type="button" class="chip-next" data-tok=">" data-route="next: the only live word — returns tomorrow as carry-over"><span class="tok">&gt;</span> next</button>
          </div>

          <div class="entries" id="c-entries">
            <p class="empty" id="c-empty">nothing logged yet today — one line is enough.</p>
          </div>
        </div>

        <div class="ej-card card carry" id="c-carry-card" hidden>
          <div class="carry-head">
            <span class="carry-label"><span id="c-carry-mode">CARRY-OVER</span> — NEXT FROM <span id="c-carry-from"></span></span>
            <span class="carry-hint" id="c-carry-hint">zero-thought resume</span>
          </div>
          <div id="c-carry"></div>
        </div>

        <!-- 字段语义常驻但只占一行(2026-07-12 文字减负): 词 + ≤2 词提示, 完整注解走悬停 RouteHint -->
        <div class="syntax">
          <span class="syn-word" data-route="done: no prefix — result, it got finished"><span class="s-done">done</span> <span class="syn-dim">result</span></span>
          <span class="syn-word" data-route="@ wip: effort — log it the moment you start; wip now + done later is a feature"><span class="s-wip">@</span> wip <span class="syn-dim">effort</span></span>
          <span class="syn-word" data-route="= decision: archive only"><span class="s-decision">=</span> decision</span>
          <span class="syn-word" data-route="! risk: archive only"><span class="s-risk">!</span> risk</span>
          <span class="syn-word" data-route="> next: the only live word — tomorrow it returns as carry-over and demands an exit"><span class="s-next">&gt;</span> next <span class="syn-dim">returns tomorrow</span></span>
          <span class="syn-word" data-route="~ dropped: a dignified exit — usually happens in triage, not at the keyboard"><span class="s-dropped">~</span> drop</span>
        </div>
      </div>

      <div class="col-r">
        <div class="ej-card card file">
          <div class="file-head">
            <a class="file-path" id="c-path" href="/worklog/archive/" data-route="→ /worklog/archive/ — every week ever logged">content/worklogs/….md</a>
            <span class="file-meta"><span>D1 · draft</span><span class="diff" id="c-diff">+0 −0</span></span>
          </div>
          <!-- live 区(亮) = D1 草稿在上, 回看区(压暗) = 当月已提交的日子在下 — 月文件是倒序的
               (最新在顶), close 会把草稿 prepend 到文件顶部, 预览从上往下读就是 close 后的文件. -->
          <div class="md" id="c-md">
            <div id="c-md-live"></div>
            <div class="md-past" id="c-md-past"></div>
          </div>
          <div class="commit">
            <div class="ritual" id="c-ritual" hidden>
              <div class="rit-head">
                <span class="rit-label" id="c-rit-label">DAY CLOSE — UNDER A MINUTE</span>
                <button type="button" id="c-rit-x" data-route="not yet — keep logging">× not yet</button>
              </div>
              <p class="rit-recap" id="c-recap"></p>
              <div class="rit-next" id="c-rit-next-wrap">
                <span class="rit-sub">SAVE POINT — FIRST THING TOMORROW</span>
                <input id="c-rit-next" type="text" placeholder="one line — logged as > next" autocomplete="off" />
              </div>
              <p class="rit-havenext" id="c-rit-havenext" hidden><span>save point ✓</span> — <span id="c-rit-nextprev"></span></p>
              <div class="rit-public">
                <div class="rit-public-head">
                  <span class="rit-sub rit-sub-pink"><span class="pink-dot" aria-hidden="true"></span>PUBLIC LINE — HOMEPAGE “NOW”</span>
                  <span class="rit-count" id="c-count">0/140</span>
                </div>
                <input id="c-summary" type="text" maxlength="140" placeholder="one sentence for everyone else…" autocomplete="off" />
              </div>
              <div class="rit-energy">
                <span class="rit-sub">ENERGY</span>
                <span class="e-dots" id="c-energy">
                  <button type="button" data-n="1">1</button>
                  <button type="button" data-n="2">2</button>
                  <button type="button" data-n="3">3</button>
                  <button type="button" data-n="4">4</button>
                  <button type="button" data-n="5">5</button>
                </span>
                <span class="rit-opt">optional — patterns, not grades</span>
              </div>
            </div>
            <div class="commit-bar">
              <span class="commit-msg" id="c-msg">nothing to commit</span>
              <button type="button" id="c-commit" disabled>nothing to commit</button>
            </div>
            <div id="c-commit-lines"></div>
          </div>
        </div>

        <div class="ej-card card trail-card">
          <div class="trail-head">
            <span class="trail-label">LOG TRAIL — 26 WEEKS</span>
            <a href="/worklog/" data-route="→ /worklog/ — the full log">worklog →</a>
          </div>
          <div class="trail" id="c-trail"></div>
          <p class="trail-note" id="c-trailnote">gaps are neutral — no streaks, no guilt.</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline type="application/json" id="c-data" set:html={JSON.stringify(consoleData)} />

<script>
  type EntryType = 'wip' | 'done' | 'decision' | 'risk' | 'next' | 'dropped';
  type Entry = { id: number; type: EntryType; text: string; time: string };

  const RAW = JSON.parse(document.getElementById('c-data')!.textContent || '{}') as {
    nextDays: { date: string; texts: string[] }[];
    lastNote: string;
    activityDays: { date: string; count: number }[];
    monthBodies: Record<string, string>;
  };

  const $ = <T extends HTMLElement = HTMLElement>(id: string) =>
    document.getElementById(id) as T;

  const TYPE_META: Record<EntryType, { label: string; cls: string; color: string; border: string; bg: string }> = {
    wip: { label: 'WIP', cls: 't-wip', color: '#c8c8cd', border: 'rgba(255,255,255,0.22)', bg: 'transparent' },
    done: { label: 'DONE', cls: 't-done', color: '#e8e8ea', border: 'transparent', bg: 'rgba(255,255,255,0.08)' },
    decision: { label: 'DECISION', cls: 't-decision', color: '#9ed9ff', border: 'rgba(76,194,255,0.38)', bg: 'transparent' },
    risk: { label: 'RISK', cls: 't-risk', color: '#ff9d9d', border: 'rgba(255,120,120,0.4)', bg: 'transparent' },
    next: { label: 'NEXT', cls: 't-next', color: '#fcd34d', border: 'transparent', bg: 'rgba(245,158,11,0.14)' },
    dropped: { label: 'DROPPED', cls: 't-dropped', color: '#8a8a94', border: 'rgba(255,255,255,0.16)', bg: 'transparent' },
  };
  const SECTION: Record<EntryType, string> = {
    wip: 'WIP',
    done: 'Done',
    decision: 'Decision',
    risk: 'Risk',
    next: 'Next',
    dropped: 'Dropped',
  };

  // ---- 逻辑日: JST − 4h(凌晨算前一天) ----
  const jstNow = () => new Date(Date.now() + 9 * 3600_000);
  const iso = (d: Date) => d.toISOString().slice(0, 10);
  const logicalDate = () => iso(new Date(jstNow().getTime() - 4 * 3600_000));
  const isNightSession = () => iso(jstNow()) !== logicalDate();
  const jstClock = () => jstNow().toISOString().slice(11, 19);
  const jstHM = () => jstNow().toISOString().slice(11, 16);

  const today = logicalDate();
  const LS_KEY = `ej-console-${today}`;
  const filePathOf = (d: string) => `content/worklogs/${d.slice(0, 7)}.md`;
  const wdOf = (d: string) =>
    new Date(`${d}T12:00:00Z`).toLocaleDateString('en-US', { weekday: 'short', timeZone: 'UTC' }).toUpperCase();

  // ---- 关日即翻页的视图状态: server 是真相(GET /api/log 的 closed / effectiveDay / staleDays) ----
  let todayClosed = false; // 今日已关 → EARLY START(录入台照常, 行落明天; close 钮锁到 04:00)
  let effectiveDay = today; // 落笔日: 今日已关时 = 下一逻辑日
  let staleDays: string[] = []; // 漏关的过去日(旧→新), 顶部横幅从最旧的开始补
  let closingStale: string | null = null; // 补关模式: 正在补关的那一天
  const viewDay = () => closingStale ?? effectiveDay;

  // carry-over 首屏/离线占位: 构建快照里"今天之前"最近一天的 next.
  // loadDay 拿到 server 的 effectiveDay 与 D1 实时 carry 后会重算(见下), 覆盖此占位.
  const carrySource = RAW.nextDays.find((d) => d.date < today);
  const DATA = {
    carry: carrySource?.texts ?? [],
    carryFrom: carrySource?.date ?? '',
    lastNote: RAW.lastNote,
    counts: new Map(RAW.activityDays.map((d) => [d.date, d.count])),
  };

  // ---- 状态 ----
  type State = {
    entries: Entry[];
    usedCarry: number[];
    droppedCarry: number[];
    summary: string;
    energy: number;
  };
  const state: State = {
    entries: [],
    usedCarry: [],
    droppedCarry: [],
    summary: '',
    energy: 0,
  };
  let ritualOpen = false;
  let ritualNext = '';
  let pushCount = 0; // 本 session 成功 push 的次数(补关也算) — trail 今日格 +N

  // ---- /api 通道(D1 工作区): 每次操作即存, 失败不缓冲 — 报错 + 重试(已定论) ----
  const toApi = (t: EntryType) => (t === 'dropped' ? 'drop' : t);
  // 旧词兼容: 改词前入库的 D1 行还是 project(server 只在编 md 时归一, GET 原样返回)
  const fromApi = (t: string): EntryType => (t === 'drop' ? 'dropped' : t === 'project' ? 'wip' : (t as EntryType));
  const hmOf = (iso: string) => new Date(new Date(iso).getTime() + 9 * 3600_000).toISOString().slice(11, 16);
  let publicId = 0; // 今日 public 行在 D1 里的 id(0 = 还没入库)

  async function api(path: string, body?: unknown): Promise<any> {
    const res = await fetch(
      path,
      body ? { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(body) } : undefined,
    );
    const data = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(data.error ?? `HTTP ${res.status}`);
    return data;
  }

  // 提示行(成功灰 / 失败玫瑰红 + 重试钮), 一次只显示一条
  const note = (text: string, err = false, retry?: () => void) => {
    const box = $('c-commit-lines');
    box.textContent = '';
    const p = document.createElement('p');
    p.className = 'commit-line' + (err ? ' err' : '');
    p.textContent = text;
    if (retry) {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'cl-retry';
      b.textContent = '↻ retry';
      b.addEventListener('click', () => {
        box.textContent = '';
        retry();
      });
      p.append(' ', b);
    }
    box.append(p);
  };

  const parse = (t: string): { type: EntryType; text: string } => {
    const map: Record<string, EntryType> = {
      '@': 'wip',
      '=': 'decision',
      '!': 'risk',
      '>': 'next',
      '~': 'dropped',
    };
    const c = t.charAt(0);
    if (map[c]) return { type: map[c], text: t.slice(1).trim() };
    return { type: 'done', text: t };
  };

  // ---- markdown 生成(和站点解析器同一格式) ----
  const mdLines = (): string[] => {
    const lines = [`## ${viewDay()}`];
    if (state.energy) lines.push(`<!-- energy: ${state.energy} -->`);
    for (const type of ['wip', 'done', 'decision', 'risk', 'next', 'dropped'] as EntryType[]) {
      const items = state.entries.filter((e) => e.type === type);
      if (!items.length) continue;
      lines.push('', `### ${SECTION[type]}`);
      for (const item of items)
        lines.push(type === 'dropped' ? `- ~~${item.text}~~` : `- ${item.text}`);
    }
    if (state.summary.trim()) lines.push('', '### Public', `- ${state.summary.trim()}`);
    return lines;
  };

  // ---- 渲染 ----
  const input = $<HTMLInputElement>('c-input');
  const preview = $('c-preview');
  const chipEls = [...document.querySelectorAll<HTMLButtonElement>('#c-chips button')];

  const renderPreviewChip = () => {
    const t = input.value.trim();
    const first = t.charAt(0);
    for (const chip of chipEls) chip.classList.toggle('active', chip.dataset.tok === first);
    if (!t) {
      preview.className = 'type-preview';
      preview.textContent = '';
      preview.style.cssText = '';
      return;
    }
    const p = parse(t);
    const meta = TYPE_META[p.type];
    preview.className = 'type-preview on';
    preview.textContent = `→ ${meta.label}`;
    preview.style.color = meta.color;
    preview.style.borderColor = meta.border;
    preview.style.background = meta.bg;
  };

  const renderEntries = () => {
    const box = $('c-entries');
    box.querySelectorAll('.entry-row').forEach((n) => n.remove());
    $('c-empty').hidden = state.entries.length > 0;
    state.entries.forEach((entry, i) => {
      const row = document.createElement('div');
      row.className = 'entry-row';
      const badge = document.createElement('span');
      badge.className = `badge ${TYPE_META[entry.type].cls}`;
      badge.textContent = TYPE_META[entry.type].label;
      const text = document.createElement('span');
      text.className = 'entry-text';
      text.textContent = entry.text;
      const time = document.createElement('span');
      time.className = 'entry-time';
      time.textContent = entry.time;
      // 列表里的行永远是未归档的工作区行(归档行根本不会被 GET 回来), 所以永远可删
      const del = document.createElement('button');
      del.className = 'entry-del';
      del.type = 'button';
      del.textContent = '×';
      del.addEventListener('click', async () => {
        try {
          await api('/api/amend', { id: entry.id, delete: true });
          state.entries.splice(i, 1);
          renderAll();
        } catch (e) {
          note(`delete failed (${(e as Error).message})`, true);
        }
      });
      row.append(badge, text, time, del);
      box.append(row);
    });
  };

  const renderCarry = () => {
    const card = $('c-carry-card');
    // 补关模式不分诊(那一天的分诊时刻已经过去了, 直接进仪式). EARLY START 不再整卡隐藏 —
    // 改为只读 SAVE POINT: 刚关日的 next 立刻可见, 但不给出口按钮("刚立的 next 不在同夜分诊"
    // 原则照旧); 04:00 整页刷新后自然转回可分诊的 CARRY-OVER.
    if (!DATA.carry.length || closingStale) {
      card.hidden = true;
      return;
    }
    const readOnly = todayClosed;
    card.hidden = false;
    $('c-carry-mode').textContent = readOnly ? 'SAVE POINT' : 'CARRY-OVER';
    $('c-carry-hint').textContent = readOnly ? 'returns for triage at 04:00' : 'zero-thought resume';
    $('c-carry-from').textContent = DATA.carryFrom;
    const box = $('c-carry');
    box.textContent = '';
    if (readOnly) {
      DATA.carry.forEach((text) => {
        const row = document.createElement('div');
        row.className = 'carry-row';
        const t = document.createElement('span');
        t.className = 'carry-text';
        t.textContent = text;
        row.append(t);
        box.append(row);
      });
      return;
    }
    DATA.carry.forEach((text, i) => {
      const used = state.usedCarry.includes(i);
      const dropped = state.droppedCarry.includes(i);
      const row = document.createElement('div');
      row.className = 'carry-row' + (used || dropped ? ' spent' : '');
      const t = document.createElement('span');
      t.className = 'carry-text' + (used || dropped ? ' strike' : '');
      t.textContent = text;
      row.append(t);
      if (used || dropped) {
        const label = document.createElement('span');
        label.className = 'carry-spent';
        label.textContent = dropped ? 'DROPPED —' : 'LOGGED ✓';
        row.append(label);
      } else {
        const actions = document.createElement('span');
        actions.className = 'carry-actions';
        const mk = (label: string, cls: string, fn: () => void) => {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = cls;
          b.textContent = label;
          b.addEventListener('click', fn);
          return b;
        };
        actions.append(
          mk('✓ done', 'ca ca-done', () => useCarry(i, 'done')),
          mk('→ still next', 'ca ca-amber', () => useCarry(i, 'next')),
          mk('× drop', 'ca ca-drop', () => useCarry(i, 'dropped')),
        );
        row.append(actions);
      }
      box.append(row);
    });
  };

  const useCarry = async (i: number, type: EntryType) => {
    if (!(await addEntry(type, DATA.carry[i]))) return; // 没存上就不算分诊过
    (type === 'dropped' ? state.droppedCarry : state.usedCarry).push(i);
    renderCarry();
    renderCommit();
  };

  // 昨天的 next 不给出口(done / still next / drop)就不准关今天 — 迁移即对抗
  const pendingCarry = () =>
    DATA.carry.filter((_, i) => !state.usedCarry.includes(i) && !state.droppedCarry.includes(i))
      .length;

  const mdLineEl = (line: string) => {
    const div = document.createElement('div');
    div.textContent = line || ' ';
    if (line.startsWith('## ')) div.className = 'md-h2';
    else if (line.startsWith('### ')) div.className = 'md-h3';
    else if (line.startsWith('<!--')) div.className = 'md-dim';
    else if (line.startsWith('- ~~')) div.className = 'md-dropped';
    else div.className = 'md-line';
    return div;
  };

  // 钉顶: 默认贴着顶部(live 草稿块 — 文件倒序, 顶部才是最新); 手动下滚读过去后, render 不回拽
  const mdBox = $('c-md');
  let mdPinned = true;
  mdBox.addEventListener('scroll', () => {
    mdPinned = mdBox.scrollTop < 40;
  });

  // 灰色回看区 = 视图日所在月文件的构建期快照; 只在月份切换时重建(每次按键的 render 不碰它)
  let pastMonth: string | null = null;
  const renderPast = () => {
    const m = viewDay().slice(0, 7);
    if (m === pastMonth) return;
    pastMonth = m;
    const box = $('c-md-past');
    box.textContent = '';
    const body = (RAW.monthBodies ?? {})[m];
    if (!body) return;
    for (const line of body.trim().split('\n')) box.append(mdLineEl(line));
  };

  const renderMd = () => {
    renderPast();
    const box = $('c-md-live');
    box.textContent = '';
    const lines = mdLines();
    for (const line of lines) box.append(mdLineEl(line));
    $('c-diff').textContent = `+${lines.length} −0`;
    if (mdPinned) mdBox.scrollTop = 0;
  };

  const renderCommit = () => {
    const btn = $<HTMLButtonElement>('c-commit');
    const msg = $('c-msg');
    const n = state.entries.length;
    const d = viewDay();

    // EARLY START: 一个逻辑日最多关一次 — close 钮锁到 04:00 真正翻日
    if (todayClosed && !closingStale) {
      msg.textContent = n ? `${n} line${n === 1 ? '' : 's'} pre-logged for ${d}` : 'see you tomorrow';
      btn.disabled = true;
      btn.className = 'done';
      btn.textContent = 'closed ✓ — unlocks 04:00';
      btn.dataset.route = 'one close per logical day — capture stays open, lines land on tomorrow';
      return;
    }

    const pending = closingStale ? 0 : pendingCarry(); // 补关日的分诊时刻已过, 不设闸
    msg.textContent = ''; // 单声道: 按钮自己会说话, 消息行只在已关/EARLY START 时补充
    btn.disabled = !(n > 0 && pending === 0);
    btn.className = ritualOpen ? 'push' : '';
    btn.textContent = ritualOpen
      ? closingStale
        ? `push ${d} →`
        : 'push the day →'
      : n && pending
        ? `triage carry-over first (${pending})`
        : closingStale
          ? `close ${d}`
          : 'close the day';
    btn.dataset.route = ritualOpen
      ? 'server commits for you — no paste, no terminal'
      : n && pending
        ? "yesterday's next needs an exit — done / still next / drop"
        : n
          ? 'day close — recap · save point · public line · energy'
          : 'log something first';
  };

  const renderRitual = () => {
    $('c-ritual').hidden = !ritualOpen;
    if (!ritualOpen) return;
    $('c-rit-label').textContent = closingStale
      ? `CLOSING ${closingStale} — THE DAY YOU MISSED`
      : 'DAY CLOSE — UNDER A MINUTE';
    const counts: Partial<Record<EntryType, number>> = {};
    for (const e of state.entries) counts[e.type] = (counts[e.type] ?? 0) + 1;
    const parts: string[] = [];
    if (counts.done) parts.push(`${counts.done} done`);
    if (counts.wip) parts.push(`${counts.wip} wip`); // 投入也是证据, 上 recap
    if (counts.decision) parts.push(`${counts.decision} decision${counts.decision === 1 ? '' : 's'}`);
    if (counts.risk) parts.push(`${counts.risk} risk${counts.risk === 1 ? '' : 's'}`);
    if (counts.dropped) parts.push(`${counts.dropped} dropped`);
    if (counts.next) parts.push(`${counts.next} next`);
    $('c-recap').textContent =
      (parts.length ? parts.join(' · ') : `${state.entries.length} notes`) + ' — proof, not memory.';
    const nexts = state.entries.filter((e) => e.type === 'next');
    // 视图切换后(补关/翻页)输入框跟状态走 — 否则恢复出的 public/save point 会"看着是空的".
    // 只在值不同时写回, 免得打字中途触发 render 时光标跳到末尾.
    const nextInput = $<HTMLInputElement>('c-rit-next');
    if (nextInput.value !== ritualNext) nextInput.value = ritualNext;
    const sumInput = $<HTMLInputElement>('c-summary');
    if (sumInput.value !== state.summary) sumInput.value = state.summary;
    $('c-rit-next-wrap').hidden = nexts.length > 0;
    $('c-rit-havenext').hidden = nexts.length === 0;
    if (nexts.length) $('c-rit-nextprev').textContent = `“${nexts[nexts.length - 1].text}”`;
    $('c-count').textContent = `${state.summary.length}/140`;
    $('c-energy')
      .querySelectorAll('button')
      .forEach((b) => b.classList.toggle('on', Number(b.dataset.n) <= state.energy));
  };

  const renderTrail = () => {
    const box = $('c-trail');
    box.textContent = '';
    const base = new Date(`${today}T12:00:00Z`);
    const level = (c: number) => (c === 0 ? 0 : c <= 2 ? 1 : c <= 5 ? 2 : c <= 10 ? 3 : 4);
    for (let i = 181; i >= 0; i--) {
      const d = iso(new Date(base.getTime() - i * 86400_000));
      let count = DATA.counts.get(d) ?? 0;
      if (i === 0) count += pushCount; // 本 session 的 push(含补关 — commit 都落在真实的今天)
      const cell = document.createElement('span');
      cell.className = `cell l${level(count)}` + (i === 0 ? ' today' : '');
      cell.title =
        i === 0
          ? `today · ${count} commit${count === 1 ? '' : 's'}${pushCount ? ' (incl. this session)' : ' — nothing counts against you'}`
          : `${d}: ${count} commit${count === 1 ? '' : 's'}`;
      box.append(cell);
    }
    box.scrollLeft = box.scrollWidth; // 窄屏可横滚: 钉在"今天"一端, 历史向左翻
    $('c-trailnote').textContent = pushCount
      ? 'pushed ✓ — today deepens a shade.'
      : 'gaps are neutral — no streaks, no guilt.';
  };

  // 日期条与文件路径随视图切换(今天 / EARLY START 的明天 / 补关的那一天)
  const renderDate = () => {
    const d = viewDay();
    $('c-date').textContent = d;
    $('c-wd').textContent = wdOf(d);
    $('c-night').hidden = !isNightSession() || todayClosed || !!closingStale;
    const flag = $('c-flag');
    if (closingStale) {
      flag.hidden = false;
      flag.textContent = `closing a missed day — capture logs into ${closingStale}`;
    } else if (todayClosed) {
      flag.hidden = false;
      flag.textContent = `EARLY START — ${today} closed · logging for ${effectiveDay}`;
    } else {
      flag.hidden = true;
    }
    $('c-path').textContent = filePathOf(d);
  };

  // 漏关横幅: 从最旧的一天开始补, 一次一天
  const renderStale = () => {
    const box = $('c-stale');
    const target = staleDays[0];
    if (!target || closingStale) {
      box.hidden = true;
      return;
    }
    box.hidden = false;
    $('c-stale-text').textContent =
      staleDays.length === 1
        ? `${target} was never closed — its lines are still in the working tree.`
        : `${staleDays.length} days were never closed — starting with ${target}, one at a time.`;
    $('c-stale-btn').textContent = `close ${target} →`;
  };

  const renderAll = () => {
    renderDate();
    renderStale();
    renderEntries();
    renderCarry();
    renderMd();
    renderCommit();
    renderRitual();
    renderTrail();
    renderPreviewChip();
    // 录入台永不禁用(第一戒律) — 唯一例外是 API 不可达(boot 的 catch 里单独设)
    input.disabled = false;
    input.placeholder = closingStale
      ? `logging into ${closingStale} — anything you forgot? Enter to log`
      : todayClosed
        ? `early start — this line lands on ${effectiveDay}`
        : 'type what happened… Enter to log';
  };

  const addEntry = async (type: EntryType, text: string): Promise<boolean> => {
    const clean = text.trim();
    if (!clean) return false;
    try {
      const body: Record<string, unknown> = { type: toApi(type), text: clean };
      if (closingStale) body.day = closingStale; // 补关模式: 行回填到那一天
      const r = await api('/api/log', body);
      // server 说这行落在别的日子(04:00 翻日 / 别的标签页刚关了今天)→ 以 server 为准重同步
      if (!closingStale && r.day !== effectiveDay) {
        await loadDay();
        return true;
      }
      state.entries.push({ id: r.id as number, type, text: clean, time: jstHM() });
      renderAll();
      return true;
    } catch (e) {
      note(`line not saved (${(e as Error).message})`, true, () => void addEntry(type, clean));
      return false;
    }
  };

  // ---- 事件 ----
  input.addEventListener('input', renderPreviewChip);
  input.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter') return;
    const p = parse(input.value.trim());
    if (!p.text) return;
    input.value = '';
    addEntry(p.type, p.text);
  });

  $('c-chips')
    .querySelectorAll<HTMLButtonElement>('button')
    .forEach((chip) => {
      chip.addEventListener('click', () => {
        input.value = `${chip.dataset.tok} ${input.value.replace(/^[@=!>~]\s*/, '')}`;
        input.focus();
        renderPreviewChip();
      });
    });

  $('c-commit').addEventListener('click', async () => {
    if (todayClosed && !closingStale) return; // 一逻辑日一关, 锁到 04:00
    if (!state.entries.length || (!closingStale && pendingCarry() > 0)) return;
    if (!ritualOpen) {
      ritualOpen = true;
      renderCommit();
      renderRitual();
      $<HTMLInputElement>('c-summary').value = state.summary;
      return;
    }
    // push the day: save point 入库 → public 行入库 → /api/close(server 编 md + git 提交)
    const btn = $<HTMLButtonElement>('c-commit');
    btn.disabled = true;
    btn.textContent = 'pushing…';
    const closeDay = viewDay();
    try {
      const nextVal = ritualNext.trim();
      if (nextVal && !state.entries.some((e) => e.type === 'next')) {
        if (!(await addEntry('next', nextVal))) throw new Error('save point not saved');
        ritualNext = '';
      }
      const summary = state.summary.trim();
      if (summary) {
        if (publicId) await api('/api/amend', { id: publicId, text: summary });
        else {
          const body: Record<string, unknown> = { type: 'public', text: summary };
          if (closingStale) body.day = closingStale;
          publicId = (await api('/api/log', body)).id as number;
        }
      }
      const r = await api('/api/close', { day: closeDay, energy: state.energy || undefined });
      if (r.mode === 'dry-run') {
        // server 没配 GITHUB_TOKEN 才会走到这: 明示配置问题, 不假装成功
        note('dry-run only — GITHUB_TOKEN is not configured on the server, nothing was pushed', true);
        renderCommit();
        renderRitual();
        return;
      }
      pushCount += 1;
      ritualOpen = false;
      closingStale = null;
      note(`✓ pushed ${String(r.commit ?? '').slice(0, 7)} — ${r.path} · site rebuilds itself`);
      await loadDay(); // 关日即翻页: 立即切 EARLY START(补关则回到今天)
    } catch (e) {
      note(`push failed (${(e as Error).message})`, true);
      renderCommit();
      renderRitual();
    }
  });

  $('c-rit-x').addEventListener('click', () => {
    ritualOpen = false;
    if (closingStale) {
      // 退出补关模式, 回到今天(横幅还在, 想关随时再来)
      closingStale = null;
      void loadDay();
      return;
    }
    renderCommit();
    renderRitual();
  });

  // 漏关横幅 → 一键进那一天的完整仪式
  $('c-stale-btn').addEventListener('click', () => {
    const target = staleDays[0];
    if (target) void enterStale(target);
  });

  async function enterStale(day: string) {
    try {
      const data = await api(`/api/log?day=${day}`);
      closingStale = day;
      state.entries = [];
      state.summary = '';
      state.energy = 0;
      publicId = 0;
      ritualNext = '';
      for (const row of data.lines as { id: number; type: string; text: string; created_at: string }[]) {
        if (row.type === 'public') {
          state.summary = row.text;
          publicId = row.id;
          continue;
        }
        state.entries.push({ id: row.id, type: fromApi(row.type), text: row.text, time: hmOf(row.created_at) });
      }
      ritualOpen = true; // 一键即仪式
      renderAll();
    } catch (e) {
      note(`couldn't load ${day} (${(e as Error).message})`, true);
    }
  }
  $<HTMLInputElement>('c-rit-next').addEventListener('input', (e) => {
    ritualNext = (e.target as HTMLInputElement).value;
  });
  $<HTMLInputElement>('c-summary').addEventListener('input', (e) => {
    state.summary = (e.target as HTMLInputElement).value.slice(0, 140);
    $('c-count').textContent = `${state.summary.length}/140`;
    renderMd();
    renderCommit();
  });
  $('c-energy')
    .querySelectorAll<HTMLButtonElement>('button')
    .forEach((b) => {
      b.addEventListener('click', () => {
        const n = Number(b.dataset.n);
        state.energy = state.energy === n ? 0 : n;
        renderRitual();
        renderMd();
      });
    });

  // ---- 时钟与日期条(日期/星期/文件路径归 renderDate 管, 随视图切换) ----
  // last note: 先渲快照值, loadDay 拿到 D1 实时 lastClosed 后合并重渲(刚 close 完不再显示旧日)
  const renderLast = () => {
    if (!DATA.lastNote) return;
    const ago = Math.max(
      0,
      Math.round((new Date(`${today}T12:00:00Z`).getTime() - new Date(`${DATA.lastNote}T12:00:00Z`).getTime()) / 86400_000),
    );
    $('c-last').textContent = `last note ${DATA.lastNote} · ${ago}d ago`;
  };
  renderLast();
  const tick = () => {
    $('c-clock').textContent = jstClock();
    // 04:00 真正翻日: 空闲时(没在打字/仪式没开)整页刷新 — EARLY START 解锁, 日期条翻页
    if (logicalDate() !== today && !input.value && !ritualOpen && !closingStale) location.reload();
  };
  tick();
  setInterval(tick, 1000);

  // ---- 启动/重同步: 从 D1 恢复现场(closed / effectiveDay / staleDays 都以 server 为准);
  //      旧 local-mode 草稿(localStorage)一次性迁移只在首次载入做 ----
  let booted = false;
  async function loadDay() {
    const data = await api('/api/log');
    todayClosed = !!data.closed;
    effectiveDay = (data.effectiveDay as string) ?? (data.day as string);
    staleDays = (data.staleDays as string[]) ?? [];
    let rows = data.lines as { id: number; type: string; text: string; created_at: string }[];

    // carry-over 重算: 基准是 effectiveDay(关日即翻页后 = 明天), 不是 today —— 否则刚关那天的
    // next 会被 "< today" 排除. 取构建快照(含手写历史)与 D1 实时(刚关日, 不等重建)里日期更新的一个.
    {
      type Carry = { date: string; texts: string[] };
      const snap = (RAW.nextDays.find((d) => d.date < effectiveDay) ?? null) as Carry | null;
      const live: Carry | null = data.carry?.texts?.length ? (data.carry as Carry) : null;
      const pick = [snap, live].filter((c): c is Carry => !!c).sort((a, b) => (a.date < b.date ? 1 : -1))[0];
      DATA.carry = pick?.texts ?? [];
      DATA.carryFrom = pick?.date ?? '';
    }

    // last note 同理取快照与 D1 实时里更新的一个(ISO 日期字符串比较即可)
    const lastClosed = data.lastClosed as string | null;
    if (lastClosed && lastClosed > DATA.lastNote) DATA.lastNote = lastClosed;
    renderLast();

    state.entries = [];
    state.usedCarry = [];
    state.droppedCarry = [];
    state.summary = '';
    state.energy = 0;
    publicId = 0;
    ritualNext = '';

    if (!booted && !todayClosed) {
      let legacy: { entries?: { type: EntryType; text: string }[]; summary?: string } | null = null;
      try {
        legacy = JSON.parse(localStorage.getItem(LS_KEY) || 'null');
      } catch {}
      if (!rows.length && legacy?.entries?.length) {
        for (const e of legacy.entries) await api('/api/log', { type: toApi(e.type), text: e.text });
        if (legacy.summary) state.summary = legacy.summary;
        localStorage.removeItem(LS_KEY);
        rows = (await api('/api/log')).lines;
        note(`migrated ${legacy.entries.length} local draft line${legacy.entries.length === 1 ? '' : 's'} into D1`);
      }
    }
    booted = true;

    for (const row of rows) {
      if (row.type === 'public') {
        state.summary = row.text;
        publicId = row.id;
        continue;
      }
      state.entries.push({ id: row.id, type: fromApi(row.type), text: row.text, time: hmOf(row.created_at) });
    }
    // carry 分诊状态按文本回推(D1 是现场本源, 刷新不丢)
    DATA.carry.forEach((text, i) => {
      const hit = state.entries.find((e) => e.text === text);
      if (!hit) return;
      (hit.type === 'dropped' ? state.droppedCarry : state.usedCarry).push(i);
    });
    renderAll();
  }

  async function boot() {
    try {
      await loadDay();
    } catch (e) {
      renderAll();
      input.disabled = true;
      input.placeholder = 'console API unreachable — hand-write the month file';
      note(`console API unreachable (${(e as Error).message}) — hand-write src/${filePathOf(today)}, or`, true, () =>
        location.reload(),
      );
    }
  }
  boot();
</script>

