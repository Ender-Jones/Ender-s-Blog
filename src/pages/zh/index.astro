---
// /zh/ 中文主页: 镜像 / 的全部区块(2026-07-23 升级 — 此前是文章列表, 列表已搬 /zh/writing/).
// 数据: hero/splash 来自 zh.yml, 研究面板喂 research.zh.yml, 文章区列 zh 文章;
// readout 卡/LIVE 条/commit 墙/NOW 行是 mono chrome, 按既定规则保持英文, 组件直接共用.
// 语言开关对位: /zh/ ↔ /(主页对主页).
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Splash from '../../components/home/Splash.astro';
import RouteHint from '../../components/home/RouteHint.astro';
import Hero from '../../components/home/Hero.astro';
import LiveStrip from '../../components/home/LiveStrip.astro';
import ResearchSection from '../../components/home/ResearchSection.astro';
import WritingSection from '../../components/home/WritingSection.astro';
import ProofWall from '../../components/home/ProofWall.astro';
import Coda from '../../components/Coda.astro';
import { zh, researchZh } from '../../lib/data';
---

<BaseLayout title="Ender's Blog · 中文" description={zh.hero.body} lang="zh" langAlt="/" noindex>
  <Splash greeting={zh.splash.greeting} claim={zh.hero.claim} claimEm={zh.hero.claim_em} hint="English — 右上角 EN 切换" />
  <RouteHint />
  <main>
    <Hero hero={zh.hero} claimEm={zh.hero.claim_em} researchHref="/zh/research/" t={{ research: '研究与 CV →', reach: '找到我' }} />
    <div class="reveal" style="--reveal-i: 0;">
      <LiveStrip />
    </div>
    <ResearchSection data={researchZh} base="/zh/research/" />
    <WritingSection lang="zh" hub="/zh/writing/" t={{ sub: '随笔 · 诗 · 研究笔记', all: '全部文章 →', read: '读 →' }} />
    <ProofWall />
    <Coda lang="zh" revealIndex={4} screen="coda" />
  </main>
</BaseLayout>
