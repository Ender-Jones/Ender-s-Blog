---
// 全部文章: 筛选 chips + 年份分组 + 签名式行悬停(与主页同一套词汇, 多一行 desc).
import BaseLayout from '../../components/layout/BaseLayout.astro';
import RouteHint from '../../components/home/RouteHint.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter((p) => p.data.language === 'en')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const newestId = posts[0]?.id;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' });
const minutes = (body: string | undefined) =>
  Math.max(1, Math.ceil((body ?? '').split(/\s+/).filter(Boolean).length / 200));
const toneOf = (kind: string) => (kind === 'poem' || kind === 'essay' ? 'pink' : 'blue');
const kindLabel = (kind: string) =>
  kind === 'research-note' ? 'note' : kind === 'field-report' ? 'field' : kind;
const href = (id: string) => `/posts/${id.replace(/\.(md|mdx)$/, '')}/`;

const KIND_ORDER = ['essay', 'poem', 'note', 'field'];
const kinds = [...new Set(posts.map((p) => kindLabel(p.data.kind)))].sort(
  (a, b) => KIND_ORDER.indexOf(a) - KIND_ORDER.indexOf(b),
);
const years = [...new Set(posts.map((p) => String(p.data.date.getFullYear())))];
const groups = years.map((year) => ({
  year,
  posts: posts.filter((p) => String(p.data.date.getFullYear()) === year),
}));
---

<BaseLayout title="Writing — Ender Jones" description="Slow essays, occasional poems, and notes written to be checked against later." lang="en" langAlt="/zh/writing/">
  <RouteHint />
  <main style="--ej-page-w: 980px;">
    <section class="reveal" style="--reveal-i: 0;">
      <p class="ej-kicker">WRITING — ESSAYS · POEMS · RESEARCH NOTES</p>
      <h1 class="ej-h1">Writing.<span class="ej-caret" aria-hidden="true"></span></h1>
      <p class="ej-sub">Slow essays, occasional poems, and notes written to be checked against later.</p>
    </section>

    <section class="filter reveal" style="--reveal-i: 1;">
      <div class="chips" id="kind-chips">
        <button class="chip active" type="button" data-kind="all">ALL</button>
        {kinds.map((k) => (
          <button class="chip" type="button" data-kind={k}>{k.toUpperCase()}S</button>
        ))}
        <span class="count" id="post-count">{posts.length} of {posts.length} posts</span>
      </div>
    </section>

    <section class="list reveal" style="--reveal-i: 2;">
      {groups.map((g) => (
        <div class="group" data-year={g.year}>
          <div class="group-head">
            <span class="year">{g.year}</span>
            <span class="rule" aria-hidden="true"></span>
            <span class="group-count">{g.posts.length} post{g.posts.length === 1 ? '' : 's'}</span>
          </div>
          {g.posts.map((p) => {
            const tone = toneOf(p.data.kind);
            const kl = kindLabel(p.data.kind);
            const badge = p.data.pinned ? 'PINNED' : p.id === newestId ? 'LATEST' : '';
            return (
              <a class:list={['row', `tone-${tone}`]} data-kind={kl} href={href(p.id)} data-route={`→ ${href(p.id)}`}>
                <span class="bar" aria-hidden="true"></span>
                <span class="date">{fmtDate(p.data.date)}</span>
                <span class="mid">
                  <span class="title-line">
                    <strong class="title">{p.data.title}</strong>
                    {badge && <span class="badge">{badge}</span>}
                  </span>
                  {p.data.description && <span class="desc">{p.data.description}</span>}
                </span>
                <span class="meta">{kl} · {minutes(p.body)} min</span>
                {p.data.image && <span class="thumb" style={`background-image: url('${p.data.image}');`} aria-hidden="true"></span>}
              </a>
            );
          })}
        </div>
      ))}
      <p class="tail">the archive grows slowly, on purpose — every post is checked against its worklog trail.</p>
    </section>
  </main>
</BaseLayout>

<script>
  const chips = [...document.querySelectorAll<HTMLButtonElement>('#kind-chips .chip')];
  const rows = [...document.querySelectorAll<HTMLElement>('.row[data-kind]')];
  const groups = [...document.querySelectorAll<HTMLElement>('.group')];
  const count = document.getElementById('post-count');

  const apply = (kind: string) => {
    let visible = 0;
    for (const row of rows) {
      const on = kind === 'all' || row.dataset.kind === kind;
      row.style.display = on ? '' : 'none';
      if (on) visible += 1;
    }
    for (const group of groups) {
      const n = [...group.querySelectorAll<HTMLElement>('.row')].filter(
        (r) => r.style.display !== 'none',
      ).length;
      group.style.display = n ? '' : 'none';
      const label = group.querySelector('.group-count');
      if (label) label.textContent = `${n} post${n === 1 ? '' : 's'}`;
    }
    if (count) count.textContent = `${visible} of ${rows.length} posts`;
  };

  for (const chip of chips) {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.toggle('active', c === chip));
      apply(chip.dataset.kind ?? 'all');
    });
  }
</script>

<style>

  .filter {
    padding: clamp(28px, 4vh, 40px) 0 0;
  }
  .chips {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .chip {
    padding: 3px 12px;
    border-radius: 999px;
    cursor: pointer;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: transparent;
    color: #9a9aa2;
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-meta);
    font-weight: var(--ej-fw-medium);
    letter-spacing: var(--ej-track-chip);
    transition: all 130ms var(--ej-ease);
  }
  .chip:hover {
    border-color: rgba(255, 255, 255, 0.24);
    color: #e8e8ea;
  }
  .chip.active {
    border-color: rgba(255, 122, 192, 0.45);
    background: rgba(255, 122, 192, 0.08);
    color: var(--ej-pink-2);
    text-shadow: 0 0 12px rgba(255, 122, 192, 0.4);
  }
  .count {
    margin-left: auto;
    color: var(--ej-mut-2); /* 信息字对比度地板 4.5:1 */
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-meta);
    font-variant-numeric: tabular-nums;
  }

  .list {
    padding: clamp(20px, 3vh, 30px) 0 clamp(56px, 8vh, 72px);
  }
  .group {
    margin: 0 0 14px;
  }
  .group-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 18px 2px 8px;
  }
  .year {
    color: var(--ej-mut);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-label);
    font-weight: var(--ej-fw-head);
    letter-spacing: var(--ej-track-label);
  }
  .rule {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.055);
    transform: translateY(-3px);
  }
  .group-count {
    color: var(--ej-mut-2); /* 信息字对比度地板 4.5:1 */
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-meta);
  }

  .row {
    position: relative;
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr) 150px;
    gap: 20px;
    align-items: baseline;
    padding: 17px 12px 17px 14px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.055);
    text-decoration: none;
    transition: background 180ms var(--ej-ease);
  }
  .row:hover {
    background: rgba(255, 255, 255, 0.014);
  }
  .bar {
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 2px;
    border-radius: 2px;
    background: var(--tone);
    box-shadow: 0 0 9px rgba(var(--tone-rgb), 0.55);
    opacity: 0;
    transform: scaleY(0.55);
    transform-origin: center;
    transition:
      opacity 180ms var(--ej-ease),
      transform 220ms var(--ej-ease);
  }
  .row:hover .bar {
    opacity: 1;
    transform: scaleY(1);
  }
  .date {
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-label);
    font-weight: var(--ej-fw-medium);
    font-variant-numeric: tabular-nums;
    transition: color 180ms ease;
  }
  .row:hover .date {
    color: #e9e9ec;
  }
  .mid {
    min-width: 0;
    display: grid;
    gap: 5px;
  }
  .title-line {
    min-width: 0;
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .title {
    color: var(--ej-text-2);
    font-family: var(--ej-serif);
    font-size: var(--ej-fs-title);
    font-weight: var(--ej-fw-body);
    letter-spacing: var(--ej-track-body);
    line-height: var(--ej-lh-snug);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
    transform: translateX(0);
    transition:
      color 180ms ease,
      transform 220ms var(--ej-ease);
  }
  .row:hover .title {
    color: #ffffff;
    transform: translateX(4px);
  }
  .badge {
    flex-shrink: 0;
    color: var(--ej-mut);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-meta);
    font-weight: var(--ej-fw-medium);
    letter-spacing: var(--ej-track-key);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    padding: 1px 7px;
  }
  .desc {
    color: #8f8f96;
    font-size: var(--ej-fs-note);
    line-height: 1.55;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
    transform: translateX(0);
    transition:
      color 180ms ease,
      transform 240ms var(--ej-ease);
  }
  .row:hover .desc {
    color: #9d9da5;
    transform: translateX(4px);
  }
  .meta {
    color: var(--ej-mut-2);
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-label);
    font-weight: var(--ej-fw-medium);
    text-align: right;
    transition: opacity 200ms ease;
  }
  .row:hover .meta {
    opacity: 0.12;
  }
  .thumb {
    position: absolute;
    right: 14px;
    top: 50%;
    width: 92px;
    height: 58px;
    border-radius: 7px;
    border: 1px solid rgba(var(--tone-rgb), 0.35);
    background-size: cover;
    background-position: center;
    box-shadow:
      0 16px 34px -14px rgba(0, 0, 0, 0.95),
      0 0 0 3px rgba(10, 10, 12, 0.65);
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transform: translateY(-46%) translateX(6px) scale(0.98);
    transition:
      opacity 200ms var(--ej-ease),
      transform 260ms var(--ej-ease);
  }
  .row:hover .thumb {
    opacity: 1;
    transform: translateY(-50%) translateX(0) scale(1);
    transition-delay: 40ms;
  }
  .tail {
    margin: 26px 0 0;
    color: var(--ej-mut-2); /* 成句要读的字, 对比度地板 4.5:1 */
    font-family: var(--ej-mono);
    font-size: var(--ej-fs-meta);
  }

  @media (max-width: 720px) {
    .row {
      grid-template-columns: 90px minmax(0, 1fr);
    }
    .meta,
    .thumb {
      display: none;
    }
    .title,
    .desc {
      white-space: normal;
    }
  }
</style>
