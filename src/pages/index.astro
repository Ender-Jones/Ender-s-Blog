---
import '../styles/tokens.css';
import '@fontsource/newsreader/400-italic.css';
import '@fontsource/geist-mono/500.css';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const worklogs = await getCollection('worklogs');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Ender Jones — rebuilding</title>
  </head>
  <body>
    <main>
      <p class="line">
        Ender Jones<span class="caret"></span>
      </p>
      <p class="meta">
        V3 under construction — {posts.length} posts · {worklogs.length} worklogs migrated
      </p>
    </main>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    padding: 0;
    background: #030305;
  }
  main {
    display: grid;
    place-content: center;
    gap: 14px;
    min-height: 100vh;
    text-align: center;
  }
  .line {
    margin: 0;
    color: var(--ej-text);
    font-family: var(--ej-serif);
    font-size: 34px;
    font-style: italic;
  }
  .caret {
    display: inline-block;
    width: 0.5em;
    height: 0.07em;
    margin-left: 0.14em;
    border-radius: 1px;
    background: var(--ej-pink);
    box-shadow: 0 0 16px rgba(255, 122, 192, 0.6);
    animation: ej-caret 1.15s linear infinite;
  }
  .meta {
    margin: 0;
    color: var(--ej-mut);
    font-family: var(--ej-mono);
    font-size: 12px;
  }
</style>
