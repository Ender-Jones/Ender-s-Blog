---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Splash from '../components/home/Splash.astro';
import RouteHint from '../components/home/RouteHint.astro';
import Hero from '../components/home/Hero.astro';
import LiveStrip from '../components/home/LiveStrip.astro';
import ResearchSection from '../components/home/ResearchSection.astro';
import WritingSection from '../components/home/WritingSection.astro';
import ProofWall from '../components/home/ProofWall.astro';
import Coda from '../components/Coda.astro';
import { home } from '../lib/data';
---

<BaseLayout title="Ender's Blog" description={home.hero.body} noindex>
  {/* 语言自动检测(只在 EN 主页, 深链不拦): 浏览器是中文且用户没表达过偏好 → /zh/;
      用户点过语言开关后以偏好为准(Nav 存 ej-lang). 内联+置顶 = 在正文解析前跑完, 避免闪屏. */}
  <script is:inline>
    (function () {
      try {
        var p = localStorage.getItem('ej-lang');
        if (p === 'zh' || (!p && /^zh/i.test(navigator.language || ''))) {
          location.replace('/zh/');
        }
      } catch (e) {}
    })();
  </script>
  <Splash />
  <RouteHint />
  <main>
    <Hero />
    <div class="reveal" style="--reveal-i: 0;">
      <LiveStrip />
    </div>
    <ResearchSection />
    <WritingSection />
    <ProofWall />
    <Coda lang="en" revealIndex={4} screen="coda" />
  </main>
</BaseLayout>
