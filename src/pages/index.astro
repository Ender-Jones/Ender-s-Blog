---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const worklogs = await getCollection('worklogs');
---

<BaseLayout title="Ender Jones — research notebook" noindex>
  <main>
    <section class="construction">
      <p class="line">
        Ender Jones<span class="caret" aria-hidden="true"></span>
      </p>
      <p class="meta">
        V3 under construction — {posts.length} posts · {worklogs.length} worklogs migrated
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .construction {
    display: grid;
    place-content: center;
    gap: 14px;
    min-height: calc(100vh - 46px - 120px);
    text-align: center;
  }
  .line {
    margin: 0;
    color: var(--ej-text);
    font-family: var(--ej-serif);
    font-size: 34px;
    font-style: italic;
  }
  .caret {
    display: inline-block;
    width: 0.5em;
    height: 0.07em;
    margin-left: 0.14em;
    border-radius: 1px;
    background: var(--ej-pink);
    box-shadow: 0 0 16px rgba(255, 122, 192, 0.6);
    animation: ej-caret 1.15s linear infinite;
  }
  .meta {
    margin: 0;
    color: var(--ej-mut);
    font-family: var(--ej-mono);
    font-size: 12px;
  }
</style>
