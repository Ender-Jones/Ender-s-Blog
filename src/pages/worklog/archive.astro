---
// Worklog 归档: 全部周分组, 一页到底.
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import RouteHint from '../../components/home/RouteHint.astro';
import WorklogWeeks from '../../components/worklog/WorklogWeeks.astro';
import { getWorklogDays, groupByWeek } from '../../lib/worklogDays';

const worklogs = await getCollection('worklogs');
const days = getWorklogDays(worklogs);
const todayIso = new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Tokyo' });
const weeks = groupByWeek(days, todayIso);
---

<BaseLayout title="Worklog archive — Ender Jones" description="Every logged week, oldest habits included." noindex>
  <RouteHint />
  <main style="--ej-page-w: 980px;">
    <section class="reveal" style="--reveal-i: 0;">
      <p class="kicker">WORKLOG — ARCHIVE</p>
      <h1>Every week.<span class="caret" aria-hidden="true"></span></h1>
      <p class="sub">{days.length} logged days across {weeks.length} weeks · <a class="ej-link" href="/worklog/" data-route="→ /worklog/">back to worklog →</a></p>
    </section>

    <section class="weeks-sec reveal" style="--reveal-i: 1;">
      <WorklogWeeks weeks={weeks} />
    </section>
  </main>
</BaseLayout>

<style>
  .kicker {
    margin: 0 0 18px;
    padding-top: clamp(48px, 8vh, 76px);
    color: #82828c;
    font-family: var(--ej-mono);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.24em;
  }
  h1 {
    margin: 0;
    color: var(--ej-text);
    font-family: var(--ej-serif);
    font-size: clamp(34px, 4vw, 50px);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }
  .caret {
    display: inline-block;
    width: 0.5em;
    height: 0.07em;
    margin-left: 0.14em;
    border-radius: 1px;
    background: var(--ej-pink);
    box-shadow: 0 0 18px rgba(255, 122, 192, 0.55);
    animation: ej-caret 1.15s linear infinite;
  }
  .sub {
    margin: 18px 0 0;
    color: var(--ej-text-3);
    font-size: 14px;
  }
  .weeks-sec {
    padding: clamp(40px, 6vh, 56px) 0 clamp(56px, 8vh, 72px);
  }
</style>
