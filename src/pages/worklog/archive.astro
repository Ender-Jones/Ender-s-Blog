---
// Worklog 归档: 全部周分组, 一页到底.
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import RouteHint from '../../components/home/RouteHint.astro';
import WorklogWeeks from '../../components/worklog/WorklogWeeks.astro';
import { getMonthCloses, getWorklogDays, groupByWeek } from '../../lib/worklogDays';

const worklogs = await getCollection('worklogs');
const days = getWorklogDays(worklogs);
const closes = getMonthCloses(worklogs);
const todayIso = new Date().toLocaleDateString('en-CA', { timeZone: 'Asia/Tokyo' });
const weeks = groupByWeek(days, todayIso);
---

<BaseLayout title="Worklog archive — Ender Jones" description="Every logged week, oldest habits included." neutral>
  <RouteHint />
  <main style="--ej-page-w: 980px;">
    <section class="reveal" style="--reveal-i: 0;">
      <p class="ej-kicker">WORKLOG — ARCHIVE</p>
      <h1 class="ej-h1 ej-h1--sm">Every week.<span class="ej-caret" aria-hidden="true"></span></h1>
      <p class="ej-sub">{days.length} logged days across {weeks.length} weeks · <a class="ej-link" href="/worklog/" data-route="→ /worklog/">back to worklog →</a></p>
    </section>

    <section class="weeks-sec reveal" style="--reveal-i: 1;">
      <WorklogWeeks weeks={weeks} closes={closes} />
    </section>
  </main>
</BaseLayout>

<style>
  .weeks-sec {
    padding: clamp(40px, 6vh, 56px) 0 clamp(56px, 8vh, 72px);
  }
</style>
